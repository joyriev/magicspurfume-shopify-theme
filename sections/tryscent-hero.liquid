{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    {% if section.settings.mobile_background_image != blank %}
      background-image: url("{{ section.settings.mobile_background_image | image_url: width: 1920 }}");
    {% endif %}
    {% if section.settings.background_color != blank %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      {% if section.settings.background_image != blank %}
        background-image: url("{{ section.settings.background_image | image_url: width: 1920 }}");
      {% endif %}
    }
  }
{%- endstyle -%}

<div id="{{ section.id }}" class="section-{{ section.id }}-padding bg-cover bg-center">
  <div class="page-width">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 itm">
      <div class="flex flex-col justify-center items-center text-center [&>*]:m-0 gap-6 md:px-10">
        <div class="inline-flex items-center bg-white rounded-full px-4 py-1.5 mb-8 shadow-sm">
          <div class="flex text-[#FFB800] mr-2">
            <!-- 5 Stars -->
            {% for i in (1..5) %}
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            {% endfor %}
          </div>
          <span class="text-xs font-bold text-gray-700">
            {{ section.settings.review_text }}
          </span>
        </div>
        <h1 class="text-3xl md:text-4xl font-black tracking-tight leading-snug">{{ section.settings.title }}</h1>
        <p class="text-lg font-medium text-gray-700">{{ section.settings.subtitle }}</p>
        <a href="{{ section.settings.button_link }}" class="bg-[#137c44] text-white uppercase tracking-wide font-medium no-underline px-6 py-3 text-lg rounded-full min-w-[300px]">{{ section.settings.button_text }}</a>
      </div>
      <div class="text-center">
        {% if section.settings.image != blank %}
          <img
            class="max-w-full h-auto"
            src="{{ section.settings.image | image_url: width: 450 }}"
            fetchpriority="high"
            alt="Hero Image"
            width="450"
            height="450">
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "TryScent Hero",
    "class": "tryscent-hero",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#fcfbf9"
      },
      {
        "type": "image_picker",
        "id": "background_image",
        "label": "Background Image"
      },
      {
        "type": "image_picker",
        "id": "mobile_background_image",
        "label": "Mobile Background Image"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image"
      }, {
        "type": "text",
        "id": "review_text",
        "label": "Review Text",
        "default": "LOVED BY 10,000 CUSTOMERS"
      }, {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Homepage Hero"
      }, {
        "type": "text",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "Homepage Hero"
      }, {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "BUY 3 GET 1 FREE - ENDS SOON!"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }, {
        "type": "text",
        "id": "secondary_button_text",
        "label": "Secondary Button Text",
        "default": "Not sure yet? Explore More →"
      }, {
        "type": "url",
        "id": "secondary_button_link",
        "label": "Secondary Button Link"
      }, {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      }, {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 400,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 400,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }, {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 400,
        "step": 4,
        "unit": "px",
        "label": "Mobile Padding Top",
        "default": 36
      }, {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 400,
        "step": 4,
        "unit": "px",
        "label": "Mobile Padding Bottom",
        "default": 36
      }
    ],
    "presets": [
      {
        "name": "TryScent Hero"
      }
    ]
  }
{% endschema %}