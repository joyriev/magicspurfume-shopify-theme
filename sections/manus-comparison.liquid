{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="{{ section.id }}"
  class="section-{{ section.id }}-padding"
  style="background-color: {{ section.settings.background_color }}">
  <div class="page-width max-w-screen-lg">
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-[#C8A96E]">Wir vs. Original</p>
      <h2 class="mt-4 text-2xl md:text-4xl font-semibold leading-snug text-[#F5F2EC]">Sie können den Duft vergleichen. Sie sollten auch die Mathematik vergleichen.</h2>
    </div>
    <div class="mt-12 overflow-hidden border border-solid border-white/10">
      <!-- Table Header -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] bg-[#1A1A2E] font-mono text-[11px] uppercase tracking-[0.22em] text-[#B0ADA6]">
        <div class="px-5 py-4">Merkmal</div>
        <div class="px-5 py-4 text-[#C8A96E]">TryScent</div>
        <div class="px-5 py-4">Original</div>
      </div>

      <!-- Price Row (Even) -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] border-0 border-t border-solid border-white/10 bg-[#14141C]">
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">Preis (50ml)</div>
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">174.99 € ✓</div>
        <div class="px-5 py-4 text-sm text-[#6B6B6B]">3.814 €</div>
      </div>

      <!-- Concentration Row (Odd) -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] border-0 border-t border-solid border-white/10 bg-[#0A0A0F]">
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">Duftkonzentration</div>
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">19–21% EDP ✓</div>
        <div class="px-5 py-4 text-sm text-[#6B6B6B]">EDP</div>
      </div>

      <!-- Longevity Row (Even) -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] border-0 border-t border-solid border-white/10 bg-[#14141C]">
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">Haltbarkeit</div>
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">12+ Stunden ✓</div>
        <div class="px-5 py-4 text-sm text-[#6B6B6B]">6–8 Stunden*</div>
      </div>

      <!-- Returns Row (Odd) -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] border-0 border-t border-solid border-white/10 bg-[#0A0A0F]">
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">Rückgaben</div>
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">60 Tage ✓</div>
        <div class="px-5 py-4 text-sm text-[#6B6B6B]">Ausverkauf</div>
      </div>

      <!-- Made In Row (Even) -->
      <div class="[display:grid] [grid-template-columns:1.1fr_1fr_1fr] border-0 border-t border-solid border-white/10 bg-[#14141C]">
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">Hergestellt in</div>
        <div class="px-5 py-4 text-sm text-[#F5F2EC]">EU-zertifiziert ✓</div>
        <div class="px-5 py-4 text-sm text-[#6B6B6B]">Frankreich</div>
      </div>
    </div>
    <div class="mt-10 text-center">
      <a href="{{ section.settings.button_url | default: '/collection' }}" class="inline-flex no-underline min-h-12 items-center justify-center gap-2 border border-[#C8A96E] bg-[#C8A96E] px-8 py-4 text-base font-semibold text-[#0A0A0F] transition duration-200 hover:scale-[1.02] hover:bg-[#d4b57c]">{{ section.settings.button_text | default: "Mehr Düfte entdecken" }}</a>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Manus Comparison",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "label": "Background Color",
        "default": "#0a0a0f"
      },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 72
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 72
      }, {
        "type": "url",
        "id": "button_url",
        "label": "Button URL"
      }, {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "Mehr Düfte entdecken"
      }
    ],
    "presets": [
      {
        "name": "Manus Comparison"
      }
    ]
  }
{% endschema %}