{% doc %}
  @prompt
    I need you to create an image banner for the top of the page collection with dedicated sizing of:
    2048 x 1024 for desktop
    and 1200 x 1600 for mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-banner-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .ai-image-banner-wrapper-{{ ai_gen_id }} {
    width: 100%;
    position: relative;
  }

  .ai-image-banner-desktop-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: auto;
  }

  .ai-image-banner-mobile-{{ ai_gen_id }} {
    display: none;
    width: 100%;
    height: auto;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-banner-placeholder-desktop-{{ ai_gen_id }} {
    aspect-ratio: 2048 / 1024;
  }

  .ai-image-banner-placeholder-mobile-{{ ai_gen_id }} {
    aspect-ratio: 1200 / 1600;
    display: none;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-image-banner-placeholder-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-banner-placeholder-mobile-{{ ai_gen_id }} {
      display: flex;
    }
  }
{% endstyle %}

<image-banner-{{ ai_gen_id }}
  class="ai-image-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-banner-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image %}
      <img
        src="{{ block.settings.desktop_image | image_url: width: 2048 }}"
        alt="{{ block.settings.desktop_image.alt | escape }}"
        loading="lazy"
        width="2048"
        height="1024"
        class="ai-image-banner-desktop-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-banner-placeholder-{{ ai_gen_id }} ai-image-banner-placeholder-desktop-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
          Add a desktop image (recommended: 2048 x 1024 px)
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image %}
      <img
        src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
        alt="{{ block.settings.mobile_image.alt | escape }}"
        loading="lazy"
        width="1200"
        height="1600"
        class="ai-image-banner-mobile-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-image-banner-placeholder-{{ ai_gen_id }} ai-image-banner-placeholder-mobile-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
          Add a mobile image (recommended: 1200 x 1600 px)
        </div>
      </div>
    {% endif %}
  </div>
</image-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('image-banner-{{ ai_gen_id }}', ImageBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection image banner",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended size: 2048 x 1024 px"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended size: 1200 x 1600 px"
    }
  ],
  "presets": [
    {
      "name": "Collection image banner"
    }
  ]
}
{% endschema %}
