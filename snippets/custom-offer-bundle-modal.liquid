<div
  x-data
  x-transition
  x-show="$store.bundleBuilder.showModal"
  class="fixed inset-0 bg-black bg-opacity-50 flex items-end md:items-center justify-center z-[9999]"
  x-cloak>
  <div class="bg-white rounded-3xl pb-3 max-w-xl w-full h-[80vh] md:h-[90vh] flex flex-col relative" @click.away="$store.bundleBuilder.showModal = false">
    <button @click="$store.bundleBuilder.showModal = false" class="absolute -top-10 right-2 md:top-2 md:right-2 w-8 h-8 bg-[#f1f4f2] text-black rounded-full flex items-center justify-center hover:bg-red-600 hover:text-white border-0 text-3xl cursor-pointer transition">
      <span class="[rotate:-45deg] size-4 flex">
        {{- 'icon-plus.svg' | inline_asset_content -}}
      </span>
    </button>
    <div class="modal-header flex-shrink-0">
      <div class="p-3 pt-5 border-0 border-b border-solid border-[#e3e8e5]">
        <h2 class="text-lg font-bold text-gray-900 my-0 text-center tracking-normal">
          <span x-show="$store.bundleBuilder.selectedProducts.length === $store.bundleBuilder.bundleLength">
            Dein Bundle ist fertig!
          </span>
          <span x-show="$store.bundleBuilder.selectedProducts.length < $store.bundleBuilder.bundleLength">
            <span>Wähle noch </span>
            <span x-text="$store.bundleBuilder.bundleLength - $store.bundleBuilder.selectedProducts.length"></span>
            <span x-show="($store.bundleBuilder.bundleLength - $store.bundleBuilder.selectedProducts.length) === 1">
              Duft aus
            </span>
            <span x-show="($store.bundleBuilder.bundleLength - $store.bundleBuilder.selectedProducts.length) > 1">
              Düfte aus
            </span>
          </span>
        </h2>
        <p class="my-0 text-center text-sm text-[#6b7280]">Stelle dein Bundle mit
          <span x-text="$store.bundleBuilder.bundleLength"></span> Flaschen zusammen</p>
      </div>
      <div x-show="$store.bundleBuilder.selectedProducts.length < $store.bundleBuilder.bundleLength" class="px-3 py-2">
        <div class="flex gap-1.5">
          <button
            @click="$store.bundleBuilder.activeCategory = 'All'"
            :class="$store.bundleBuilder.activeCategory === 'All' ? 'border-[#22613A] bg-[#22613A] text-white hover:!text-white' : 'bg-white border-gray-200'"
            class="px-2 py-1.5 rounded-full font-semibold border-2 border-solid cursor-pointer hover:text-[#22613A] hover:border-[#22613A]">Bestseller</button>
          <button
            @click="$store.bundleBuilder.activeCategory = 'fuer-maenner'"
            :class="$store.bundleBuilder.activeCategory === 'fuer-maenner' ? 'border-[#22613A] bg-[#22613A] text-white hover:!text-white' : 'bg-white border-gray-200'"
            class="px-2 py-1.5 rounded-full font-semibold border-2 border-solid cursor-pointer hover:text-[#22613A] hover:border-[#22613A]">Herren</button>
          <button
            @click="$store.bundleBuilder.activeCategory = 'fuer-frauen'"
            :class="$store.bundleBuilder.activeCategory === 'fuer-frauen' ? 'border-[#22613A] bg-[#22613A] text-white hover:!text-white' : 'bg-white border-gray-200'"
            class="px-2 py-1.5 rounded-full font-semibold border-2 border-solid cursor-pointer hover:text-[#22613A] hover:border-[#22613A]">Damen</button>
        </div>
      </div>
      <div class="px-3 pb-3">
        <div class="relative">
            <div class="absolute top-[7px] left-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3"></path></svg>
            </div>
            <input
            type="text"
            placeholder="Suchen..."
            x-model="$store.bundleBuilder.searchText"
            class="block w-full p-2 pl-8 rounded-xl border-2 border-solid cursor-pointer bg-white border-gray-200 focus:outline-none focus:border-[#22613A] focus:shadow-none focus:border-2">
        </div>
      </div>
    </div>

    {% comment %} Product Grid {% endcomment %}
    <div class="flex-1 overflow-y-auto p-3 pt-0">
      <template x-if="$store.bundleBuilder.selectedProducts.length === $store.bundleBuilder.bundleLength">
        <div class="text-center mt-10">
          <div role="status">
            <svg
              aria-hidden="true"
              class="size-20 text-gray-200 animate-spin fill-[#22613A]"
              viewBox="0 0 100 101"
              fill="none"
              xmlns="http://www.w3.org/2000/svg">
              <path d="M100 50.5908C100 78.2051 77.6142 100.591 50 100.591C22.3858 100.591 0 78.2051 0 50.5908C0 22.9766 22.3858 0.59082 50 0.59082C77.6142 0.59082 100 22.9766 100 50.5908ZM9.08144 50.5908C9.08144 73.1895 27.4013 91.5094 50 91.5094C72.5987 91.5094 90.9186 73.1895 90.9186 50.5908C90.9186 27.9921 72.5987 9.67226 50 9.67226C27.4013 9.67226 9.08144 27.9921 9.08144 50.5908Z" fill="currentColor" />
              <path d="M93.9676 39.0409C96.393 38.4038 97.8624 35.9116 97.0079 33.5539C95.2932 28.8227 92.871 24.3692 89.8167 20.348C85.8452 15.1192 80.8826 10.7238 75.2124 7.41289C69.5422 4.10194 63.2754 1.94025 56.7698 1.05124C51.7666 0.367541 46.6976 0.446843 41.7345 1.27873C39.2613 1.69328 37.813 4.19778 38.4501 6.62326C39.0873 9.04874 41.5694 10.4717 44.0505 10.1071C47.8511 9.54855 51.7191 9.52689 55.5402 10.0491C60.8642 10.7766 65.9928 12.5457 70.6331 15.2552C75.2735 17.9648 79.3347 21.5619 82.5849 25.841C84.9175 28.9121 86.7997 32.2913 88.1811 35.8758C89.083 38.2158 91.5421 39.6781 93.9676 39.0409Z" fill="currentFill" />
            </svg>
            <span class="sr-only">{{ 'accessibility.loading' | t }}</span>
          </div>
          <p class="font-semibold text-lg tracking-normal">Weiterleitung zur Kasse...</p>
        </div>
      </template>
      <template x-if="$store.bundleBuilder.selectedProducts.length < $store.bundleBuilder.bundleLength">
        <div class="flex flex-col gap-1.5">
          <template x-for="product in $store.bundleBuilder.availableProducts" :key="product.id">
            <template x-if="(product.tags.some(tag => tag === $store.bundleBuilder.activeCategory) || $store.bundleBuilder.activeCategory === 'All') &&
         ($store.bundleBuilder.searchText === '' || product.name.toLowerCase().includes($store.bundleBuilder.searchText.toLowerCase()) || (product.inspiration_name && product.inspiration_name.toLowerCase().includes($store.bundleBuilder.searchText.toLowerCase())))">
              <button
                @click="$store.bundleBuilder.addRemoveProduct(product)"
                :class="$store.bundleBuilder.isProductSelected(product.id) ? 'border-[#22613A]' : 'border-gray-200 border'"
                class="border-[1.5px] border-solid w-full p-2 flex items-center gap-2 justify-between cursor-pointer rounded-xl bg-white">
                <img
                  class="object-cover rounded-lg"
                  :src="product.image"
                  :alt="product.name"
                  width="56"
                  height="56">
                <div class="text-left flex flex-col gap-1 mr-auto">
                  <h3 class="my-0 font-bold text-base leading-tight text-black line-clamp-1" x-text="product.name"></h3>
                  <div x-show="product.inspiration_name != ''" class="flex items-center gap-2">
                    <img
                      style="filter: blur(2px);"
                      class="object-contain object-center size-6"
                      :src="product.inspiration_image"
                      :alt="product.inspiration_name"
                      width="35"
                      height="35">
                      <p class="text-xs my-0 shrink-0 text-[#6b7280]">Inspiriert von:</p>
                      <h4 x-text="product.inspiration_name" class="text-xs font-semibold my-0 line-clamp-1 inspiration_heading"></h4>
                  </div>
                </div>
                <div class="shrink-0 ml-auto text-center">
                    <div class="text-xs font-semibold text-[#6b7280]" x-text="$store.bundleBuilder.selectedVariant"></div>
                    <div class="size-8 rounded-full border-[1.5px] border-solid border-[#22613A] flex items-center justify-center text-xl text-[#22613A]" :class="{ 'bg-[#22613A]' : $store.bundleBuilder.isProductSelected(product.id) }">
                        <span x-show="!$store.bundleBuilder.isProductSelected(product.id)">+</span>
                        <svg x-show="$store.bundleBuilder.isProductSelected(product.id)" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
                    </div>
                </div>
              </button>
            </template>
          </template>
        </div>
      </template>
    </div>
  </div>
</div>
