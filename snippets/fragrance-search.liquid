      'million': ['million', 'milion', 'mil lion', '1 million', 'one million'],
      'lucky': ['lucky', 'luky', 'luckey']
    };
    
    // Check each brand mapping
    for (const [correct, misspellings] of Object.entries(brandMappings)) {
      for (const misspelling of misspellings) {
        if (queryLower.includes(misspelling) && misspelling !== correct) {
          variations.push(queryLower.replace(misspelling, correct));
        }
      }
    }
    
    // Handle "chanel blue" vs "bleu de chanel"
    if (queryLower.includes('chanel') && (queryLower.includes('blue') || queryLower.includes('bleu'))) {
      variations.push('bleu de chanel');
      variations.push('bleu chanel');
    }
    
    if (queryLower.includes('bleu') && queryLower.includes('chanel')) {
      variations.push('chanel blue');
      variations.push('blue chanel');
    }
    
    // Remove numbers from query for broader matching
    const withoutNumbers = query.replace(/\d+/g, '').trim();
    if (withoutNumbers && withoutNumbers !== query) {
      variations.push(withoutNumbers);
    }
    
    // Remove spaces for matching concatenated words
    const withoutSpaces = query.replace(/\s+/g, '');
    if (withoutSpaces !== query) {
      variations.push(withoutSpaces);
    }
    
    return [...new Set(variations)]; // Remove duplicates
  }

