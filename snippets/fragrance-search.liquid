    // ===== EXTRACT PRODUCT NUMBER FROM TITLE =====
    function extractProductNumber(title) {
      if (!title) return null;
      const match = title.match(/No\.?\s*(\d+)/i);
      return match ? match[1] : null;
    }

    // ===== FIND PERFUME BY ID =====
    function findPerfumeById(id) {
      return allPerfumes.find(p => p.id === id);
    }

    // ===== ADVANCED LEVENSHTEIN DISTANCE FOR FUZZY MATCHING =====
    function levenshteinDistance(a, b) {
      if (a.length === 0) return b.length;
      if (b.length === 0) return a.length;
      
      const matrix = [];
      
      // Initialize matrix
      for (let i = 0; i <= b.length; i++) {
        matrix[i] = [i];
      }
      
      for (let j = 0; j <= a.length; j++) {
        matrix[0][j] = j;
      }
      
      // Fill matrix
      for (let i = 1; i <= b.length; i++) {
        for (let j = 1; j <= a.length; j++) {
          if (b.charAt(i - 1) === a.charAt(j - 1)) {
            matrix[i][j] = matrix[i - 1][j - 1];
          } else {
            matrix[i][j] = Math.min(
              matrix[i - 1][j - 1] + 1, // substitution
              matrix[i][j - 1] + 1,     // insertion
              matrix[i - 1][j] + 1      // deletion
            );
          }
        }
      }
      
      return matrix[b.length][a.length];
    }

    // ===== NORMALIZE STRING FOR BETTER COMPARISON =====
    function normalizeString(str) {
      if (!str) return '';
      return str.toLowerCase()
                .replace(/[^\w\s]/g, '') // Remove punctuation
                .replace(/\s+/g, ' ')     // Normalize spaces
                .trim();
    }

    // ===== ADVANCED SIMILARITY SCORE WITH KEYWORD EXTRACTION =====
    function calculateAdvancedSimilarity(query, target) {
      if (!query || !target) return 0;
      
      const normalizedQuery = normalizeString(query);
      const normalizedTarget = normalizeString(target);
      
      // Exact match after normalization
      if (normalizedQuery === normalizedTarget) return 100;
      
      // One contains the other
      if (normalizedTarget.includes(normalizedQuery) || normalizedQuery.includes(normalizedTarget)) {
        return 80;
      }
      
      // Split into words
      const queryWords = normalizedQuery.split(' ');
      const targetWords = normalizedTarget.split(' ');
      
      let totalScore = 0;
      let matchedWords = 0;
      
      for (const qWord of queryWords) {
        if (qWord.length < 2) continue;
        
        let bestWordScore = 0;
        let bestWord = '';
        
        for (const tWord of targetWords) {
          if (tWord.length < 2) continue;
          
          // Check if one word contains the other
          if (tWord.includes(qWord) || qWord.includes(tWord)) {
            const lengthRatio = Math.min(qWord.length, tWord.length) / Math.max(qWord.length, tWord.length);
            const score = 60 * lengthRatio;
            if (score > bestWordScore) {
              bestWordScore = score;
              bestWord = tWord;
            }
            continue;
          }
          
          // Calculate Levenshtein distance for fuzzy matching
          const distance = levenshteinDistance(qWord, tWord);
          const maxLength = Math.max(qWord.length, tWord.length);
          
          if (maxLength > 0) {
            // Convert distance to similarity (0-100)
            // More forgiving for shorter words
            const threshold = qWord.length < 4 ? 0.4 : 0.3;
            const similarity = ((maxLength - distance) / maxLength) * 100;
            
            if (similarity > (100 * threshold)) {
              if (similarity > bestWordScore) {
                bestWordScore = similarity;
                bestWord = tWord;
              }
            }
          }
        }
        
        if (bestWordScore > 0) {
          totalScore += bestWordScore;
          matchedWords++;
        }
      }
      
      // Calculate average score
      if (matchedWords > 0) {
        return totalScore / matchedWords;
      }
      
      return 0;
    }

    // ===== GENERATE QUERY VARIATIONS FOR BETTER MATCHING =====
    function generateQueryVariations(query) {
      const variations = [query];
      const queryLower = query.toLowerCase();
      
      // Common brand name misspellings and variations
      const brandMappings = {
        'armani': ['armani', 'amani', 'arani', 'armany', 'armoni', 'armani'],
        'chanel': ['chanel', 'channel', 'chanell', 'shanell', 'chanel'],
        'dior': ['dior', 'diorr', 'diore', 'dior'],
        'sauvage': ['sauvage', 'savages', 'sauvage', 'savage'],
        'bleu': ['bleu', 'blue', 'blu', 'bleue'],
        'noir': ['noir', 'noire', 'nior', 'noir'],
        'musc': ['musc', 'musk', 'musck', 'musc'],
        'million': ['million', 'milion', 'mil lion', '1 million', 'one million'],
        'lucky': ['lucky', 'luky', 'luckey']
      };
      
      // Check each brand mapping
      for (const [correct, misspellings] of Object.entries(brandMappings)) {
        for (const misspelling of misspellings) {
          if (queryLower.includes(misspelling) && misspelling !== correct) {
            variations.push(queryLower.replace(misspelling, correct));
          }
        }
      }
      
      // Handle "chanel blue" vs "bleu de chanel"
      if (queryLower.includes('chanel') && (queryLower.includes('blue') || queryLower.includes('bleu'))) {
        variations.push('bleu de chanel');
        variations.push('bleu chanel');
      }
      
      if (queryLower.includes('bleu') && queryLower.includes('chanel')) {
        variations.push('chanel blue');
        variations.push('blue chanel');
      }
      
      // Remove numbers from query for broader matching
      const withoutNumbers = query.replace(/\d+/g, '').trim();
      if (withoutNumbers && withoutNumbers !== query) {
        variations.push(withoutNumbers);
      }
      
      // Remove spaces for matching concatenated words
      const withoutSpaces = query.replace(/\s+/g, '');
      if (withoutSpaces !== query) {
        variations.push(withoutSpaces);
      }
      
      return [...new Set(variations)]; // Remove duplicates
    }

