  // ===== TWO-LAYER MATCHING SYSTEM =====
  function findMatchingShopifyProduct(perfume) {
    if (!perfume || !fcProducts.length) return null;
    
    console.log('🔍 Zwei-Ebenen-Suche für:', perfume.name);
    
    // ===== LAYER 1: EXACT HARDCODED MATCH =====
    // Try to find by product number first
    if (perfume.productNumbers && perfume.productNumbers.length > 0) {
      for (const num of perfume.productNumbers) {
        const match = fcProducts.find(p => {
          const pNumber = extractProductNumber(p.title);
          return pNumber === num || pNumber === num.padStart(3, '0');
        });
        
        if (match) {
          console.log(`✅ Layer 1: Exakter Treffer über Nummer ${num}:`, match.title);
          return match;
        }
      }
    }
    
    // Try to find in hardcodedProducts by searchTerms
    const perfumeLower = perfume.name.toLowerCase();
    const perfumeBrandLower = perfume.brand.toLowerCase();
    
    const hardcodedMatch = hardcodedProducts.find(p => {
      // Check search terms
      if (p.searchTerms) {
        return p.searchTerms.some(term => 
          perfumeLower.includes(term.toLowerCase()) || 
          perfumeBrandLower.includes(term.toLowerCase())
        );
      }
      // Check brand and number
      return (p.brand && perfumeBrandLower.includes(p.brand.toLowerCase())) ||
             (p.number && perfumeLower.includes(p.number));
    });
    
    if (hardcodedMatch) {
      // Check if this product exists in fcProducts
      const existingProduct = fcProducts.find(p => {
        const pNumber = extractProductNumber(p.title);
        return pNumber === hardcodedMatch.number;
      });
      
      if (existingProduct) {
        console.log(`✅ Layer 1: Hardcoded Match existiert:`, existingProduct.title);
        return existingProduct;
      }
      
      // Create temporary product
      console.log(`✅ Layer 1: Hardcoded Match (temporär):`, hardcodedMatch.title);
      return {
        id: hardcodedMatch.id,
        title: hardcodedMatch.title,
        image: hardcodedMatch.image,
        url: hardcodedMatch.url,
        variant: hardcodedMatch.variant,
        price: hardcodedMatch.price,
        description: hardcodedMatch.title
      };
    }
    
    // ===== LAYER 2: INTELLIGENT FALLBACK SEARCH =====
    console.log('🔍 Layer 2: Intelligente Fallback-Suche...');
    
    // Extract key terms from perfume name
    const nameWords = perfume.name.toLowerCase().split(' ');
    const brandWords = perfume.brand.toLowerCase().split(' ');
    const allWords = [...new Set([...brandWords, ...nameWords])].filter(w => w.length > 2);
    
    let bestMatch = null;
    let bestScore = 0;
    
    fcProducts.forEach(product => {
      const titleLower = product.title.toLowerCase();
      let score = 0;
      
      // Brand match (highest weight)
      for (const word of brandWords) {
        if (word.length > 2 && titleLower.includes(word)) {
          score += 40;
          break;
        }
      }
      
      // Name keywords match
      for (const word of nameWords) {
        if (word.length > 2 && titleLower.includes(word)) {
          score += 20;
        }
      }
      
      // Gender match
      if (perfume.gender) {
        if (perfume.gender === 'Female' && (titleLower.includes('w') || titleLower.includes('woman') || titleLower.includes('women'))) {
          score += 10;
        } else if (perfume.gender === 'Male' && (titleLower.includes('m') || titleLower.includes('man') || titleLower.includes('men') || titleLower.includes('homme'))) {
          score += 10;
        }
      }
      
      if (score > bestScore && score > 30) {
        bestScore = score;
        bestMatch = product;
      }
    });
    
    if (bestMatch) {
      console.log(`✅ Layer 2: Bestmatch mit Score ${bestScore}:`, bestMatch.title);
      return bestMatch;
    }
    
    console.log('❌ Kein Treffer in beiden Ebenen');
    return null;
  }

  // ===== FIND PRODUCTS BY BRAND =====
  function findProductsByBrand(brand) {
    if (!brand || !fcProducts.length) return [];
    
    const brandLower = brand.toLowerCase();
    return fcProducts.filter(p => 
      p.title.toLowerCase().includes(brandLower)
    );
  }

  // ===== FIND SIMILAR PRODUCT =====
  function findSimilarProduct(perfume, excludeId) {
    if (!perfume || !fcProducts.length) return null;
    
    // First try: same brand
    const sameBrand = fcProducts.find(p => 
      p.id !== excludeId && 
      p.title.toLowerCase().includes(perfume.brand.toLowerCase())
    );
    
    if (sameBrand) return sameBrand;
    
    // Second try: similar gender
    if (perfume.gender) {
      const genderIndicator = perfume.gender === 'Female' ? ['w', 'woman'] : ['m', 'man', 'homme'];
      const sameGender = fcProducts.find(p => {
        if (p.id === excludeId) return false;
        const titleLower = p.title.toLowerCase();
        return genderIndicator.some(ind => titleLower.includes(ind));
      });
      
      if (sameGender) return sameGender;
    }
    
    return null;
  }

  // ===== RENDER PRODUCT CARD WITH NUMERIC VARIANT ID =====
  function renderProductCard(product, badge) {
    const priceFormatted = product.price ? '€' + (product.price / 100).toFixed(2) : '€11.99';
    
    let displayNumber = '';
    let displayName = product.title;
    
    const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
    if (numberMatch) {
      displayNumber = numberMatch[0];
    }
    
    const inspiredMatch = product.title.match(/Riecht wie\.\.\. (.*)/i);
    if (inspiredMatch) {
      displayName = inspiredMatch[1];
    }
    
    // Use the numeric variant ID (NOT the SKU)
    const variantId = product.variant;
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-product-title">${displayNumber ? displayNumber + ' - ' : ''}${displayName}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${variantId})">In den Warenkorb</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">Details ansehen</span>
          </div>
        </div>
      </div>
    `;
  }

