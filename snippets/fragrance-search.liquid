    // ===== TWO-LAYER MATCHING SYSTEM =====
    function findMatchingShopifyProduct(perfume) {
      if (!perfume || !fcProducts.length) return null;
      
      console.log('🔍 Zwei-Ebenen-Suche für:', perfume.name);
      
      // ===== LAYER 1: EXACT HARDCODED MATCH =====
      // Try to find by product number first
      if (perfume.productNumbers && perfume.productNumbers.length > 0) {
        for (const num of perfume.productNumbers) {
          const match = fcProducts.find(p => {
            const pNumber = extractProductNumber(p.title);
            return pNumber === num || pNumber === num.padStart(3, '0');
          });
          
          if (match) {
            console.log(`✅ Layer 1: Exakter Treffer über Nummer ${num}:`, match.title);
            return match;
          }
        }
      }
      
      // Try to find in hardcodedProducts by searchTerms
      const perfumeLower = perfume.name.toLowerCase();
      const perfumeBrandLower = perfume.brand.toLowerCase();
      
      const hardcodedMatch = hardcodedProducts.find(p => {
        // Check search terms
        if (p.searchTerms) {
          return p.searchTerms.some(term => 
            perfumeLower.includes(term.toLowerCase()) || 
            perfumeBrandLower.includes(term.toLowerCase())
          );
        }
        // Check brand and number
        return (p.brand && perfumeBrandLower.includes(p.brand.toLowerCase())) ||
               (p.number && perfumeLower.includes(p.number));
      });
      
      if (hardcodedMatch) {
        // Check if this product exists in fcProducts
        const existingProduct = fcProducts.find(p => {
          const pNumber = extractProductNumber(p.title);
          return pNumber === hardcodedMatch.number;
        });
        
        if (existingProduct) {
          console.log(`✅ Layer 1: Hardcoded Match existiert:`, existingProduct.title);
          return existingProduct;
        }
        
        // Create temporary product
        console.log(`✅ Layer 1: Hardcoded Match (temporär):`, hardcodedMatch.title);
        return {
          id: hardcodedMatch.id,
          title: hardcodedMatch.title,
          image: hardcodedMatch.image,
          url: hardcodedMatch.url,
          variant: hardcodedMatch.variant,
          price: hardcodedMatch.price,
          description: hardcodedMatch.title
        };
      }
      
      // ===== LAYER 2: INTELLIGENT FALLBACK SEARCH =====
      console.log('🔍 Layer 2: Intelligente Fallback-Suche...');
      
      // Extract key terms from perfume name
      const nameWords = perfume.name.toLowerCase().split(' ');
      const brandWords = perfume.brand.toLowerCase().split(' ');
      const allWords = [...new Set([...brandWords, ...nameWords])].filter(w => w.length > 2);
      
      let bestMatch = null;
      let bestScore = 0;
      
      fcProducts.forEach(product => {
        const titleLower = product.title.toLowerCase();
        let score = 0;
        
        // Brand match (highest weight)
        for (const word of brandWords) {
          if (word.length > 2 && titleLower.includes(word)) {
            score += 40;
            break;
          }
        }
        
        // Name keywords match
        for (const word of nameWords) {
          if (word.length > 2 && titleLower.includes(word)) {
            score += 20;
          }
        }
        
        // Gender match
        if (perfume.gender) {
          if (perfume.gender === 'Female' && (titleLower.includes('w') || titleLower.includes('woman') || titleLower.includes('women'))) {
            score += 10;
          } else if (perfume.gender === 'Male' && (titleLower.includes('m') || titleLower.includes('man') || titleLower.includes('men') || titleLower.includes('homme'))) {
            score += 10;
          }
        }
        
        if (score > bestScore && score > 30) {
          bestScore = score;
          bestMatch = product;
        }
      });
      
      if (bestMatch) {
        console.log(`✅ Layer 2: Bestmatch mit Score ${bestScore}:`, bestMatch.title);
        return bestMatch;
      }
      
      console.log('❌ Kein Treffer in beiden Ebenen');
      return null;
    }

    // ===== FIND PRODUCTS BY BRAND =====
    function findProductsByBrand(brand) {
      if (!brand || !fcProducts.length) return [];
      
      const brandLower = brand.toLowerCase();
      return fcProducts.filter(p => 
        p.title.toLowerCase().includes(brandLower)
      );
    }

    // ===== FIXED: FIND SIMILAR PRODUCT WITH STRICT SAME-BRAND + GENDER MATCHING =====
    function findSimilarProduct(perfume, excludeId) {
      if (!perfume || !fcProducts.length) return null;
      
      console.log(`🔍 Finde ähnliches Produkt für: ${perfume.name} (Brand: ${perfume.brand}, Gender: ${perfume.gender})`);
      
      // ===== STEP 1: ONLY look at products from the SAME BRAND =====
      if (perfume.brand) {
        const brandLower = perfume.brand.toLowerCase();
        
        // Get ALL products from same brand
        const sameBrandProducts = fcProducts.filter(p => {
          if (p.id === excludeId) return false;
          
          const titleLower = p.title.toLowerCase();
          
          // Check if product belongs to same brand (case insensitive)
          return titleLower.includes(brandLower) || 
                 (p.metafields?.custom?.nuta && p.metafields.custom.nuta.toLowerCase().includes(brandLower));
        });
        
        console.log(`   Gefunden: ${sameBrandProducts.length} Produkte von ${perfume.brand}`);
        
        // If no same-brand products found, return null (don't show random products)
        if (sameBrandProducts.length === 0) {
          console.log(`   ⚠️ Keine Produkte von ${perfume.brand} gefunden`);
          return null;
        }
        
        // ===== STEP 2: Strict gender detection functions =====
        const isMale = (text) => {
          const t = text.toLowerCase();
          return t.includes('(m)') || t.includes('-m') || t.includes(' for him') || 
                 t.includes(' homme') || t.includes(' men') || t.includes(' man') ||
                 t.includes('m -') || t.includes('m)');
        };
        
        const isFemale = (text) => {
          const t = text.toLowerCase();
          return t.includes('(w)') || t.includes('-w') || t.includes(' for her') || 
                 t.includes(' femme') || t.includes(' women') || t.includes(' woman') ||
                 t.includes('w -') || t.includes('w)');
        };
        
        // ===== STEP 3: Filter by gender based on original perfume =====
        let genderFilteredProducts = [];
        const perfumeGender = perfume.gender ? perfume.gender.toLowerCase() : '';
        
        // Original perfume is MEN'S
        if (perfumeGender.includes('male') || perfumeGender.includes('m') || perfumeGender.includes('homme')) {
          genderFilteredProducts = sameBrandProducts.filter(p => isMale(p.title));
          console.log(`   ${genderFilteredProducts.length} Herrenprodukte von ${perfume.brand} gefunden`);
          
          if (genderFilteredProducts.length > 0) {
            return genderFilteredProducts[0]; // Return first men's product from same brand
          }
        }
        // Original perfume is WOMEN'S
        else if (perfumeGender.includes('female') || perfumeGender.includes('w') || perfumeGender.includes('femme')) {
          genderFilteredProducts = sameBrandProducts.filter(p => isFemale(p.title));
          console.log(`   ${genderFilteredProducts.length} Damenprodukte von ${perfume.brand} gefunden`);
          
          if (genderFilteredProducts.length > 0) {
            return genderFilteredProducts[0]; // Return first women's product from same brand
          }
        }
        // Original perfume is UNISEX
        else if (perfumeGender.includes('unisex')) {
          // For unisex, prefer same brand products (any gender)
          if (sameBrandProducts.length > 0) {
            console.log(`   ✅ Unisex - zeige erstes Produkt von ${perfume.brand}`);
            return sameBrandProducts[0];
          }
        }
        
        // ===== STEP 4: If no gender-matched products, try ANY product from same brand =====
        if (sameBrandProducts.length > 0) {
          console.log(`   ⚠️ Keine gender-spezifischen Produkte, zeige beliebiges Produkt von ${perfume.brand}`);
          return sameBrandProducts[0];
        }
      }
      
      // ===== STEP 5: ABSOLUTELY NO RANDOM PRODUCTS =====
      // Return null instead of random product - better to show nothing than wrong product
      console.log(`   ❌ Keine passenden Produkte gefunden - zeige nichts`);
      return null;
    }

    // ===== RENDER PRODUCT CARD WITH NUMERIC VARIANT ID =====
    function renderProductCard(product, badge) {
      const priceFormatted = product.price ? '€' + (product.price / 100).toFixed(2) : '€11.99';
      
      let displayNumber = '';
      let displayName = product.title;
      
      const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
      if (numberMatch) {
        displayNumber = numberMatch[0];
      }
      
      const inspiredMatch = product.title.match(/Riecht wie\.\.\. (.*)/i);
      if (inspiredMatch) {
        displayName = inspiredMatch[1];
      }
      
      // Use the numeric variant ID
      const variantId = product.variant;
      
      return `
        <div class="fc-product-card">
          <div class="fc-badge">${badge}</div>
          <div class="fc-product-inner">
            <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
            <div class="fc-product-title">${displayNumber ? displayNumber + ' - ' : ''}${displayName}</div>
            <div class="fc-product-price">${priceFormatted}</div>
            <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${variantId})">In den Warenkorb</button>
            <div>
              <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">Details ansehen</span>
            </div>
          </div>
        </div>
      `;
    }

    // ===== INITIALIZE YOUR SHOPIFY PRODUCTS =====
    function fcInitProducts() {
      try {
        fcProducts = [
          {% for product in collections.all.products %}
            {
              id: {{ product.id | json }},
              title: {{ product.title | json }},
              image: {{ product.featured_image | img_url: '400x' | json }},
              url: {{ product.url | json }},
              variant: {{ product.variants.first.id | json }},
              variantSKU: {{ product.variants.first.sku | json }},
              price: {{ product.price | json }},
              comparePrice: {{ product.compare_at_price | json }},
              description: {{ product.description | strip_html | json }},
              metafields: {
                perfume: {
                  top_notes: {{ product.metafields.perfume.top_notes | default: '' | json }},
                  middle_notes: {{ product.metafields.perfume.middle_notes | default: '' | json }},
                  base_notes: {{ product.metafields.perfume.base_notes | default: '' | json }}
                },
                custom: {
                  top_notes: {{ product.metafields.custom.top_notes | default: '' | json }},
                  middle_notes: {{ product.metafields.custom.middle_notes | default: '' | json }},
                  base_notes: {{ product.metafields.custom.base_notes | default: '' | json }},
                  nuta: {{ product.metafields.custom.nuta | default: '' | json }}
                }
              }
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ];
        
        console.log('✓ Geladen', fcProducts.length, 'Produkte von Shopify');
        
        // Log all product numbers for debugging
        if (fcProducts.length > 0) {
          console.log('📋 Produktnummern in fcProducts:');
          fcProducts.forEach(p => {
            const number = extractProductNumber(p.title);
            console.log(`   ${p.title} -> Nummer: ${number}, Variant ID: ${p.variant}`);
          });
        }
      } catch (e) {
        console.error('Fehler beim Laden der Shopify-Produkte:', e);
        fcProducts = [];
      }
    }

    // ===== SHOW NOTIFICATION =====
    function showNotification(message) {
      let notification = document.querySelector('.fc-notification');
      if (!notification) {
        notification = document.createElement('div');
        notification.className = 'fc-notification';
        document.body.appendChild(notification);
      }
      
      notification.textContent = message;
      notification.classList.add('show');
      
      setTimeout(() => {
        notification.classList.remove('show');
      }, 2000);
    }

    // ===== UPDATE OFFER DISPLAY =====
    function updateOfferDisplay(itemCount) {
      if (!offerStatus || !offerProgress || !offerMessage || !offerSubtext) return;
      
      const percentage = Math.min((itemCount / 3) * 100, 100);
      offerProgress.style.width = percentage + '%';
      
      if (itemCount >= 3) {
        offerStatus.textContent = '🎉 GRATIS!';
        offerSubtext.textContent = 'Du qualifizierst dich für ein gratis Geschenk!';
        offerMessage.textContent = '🎉 Du qualifizierst dich für ein GRATIS Geschenk!';
        offerBanner.classList.add('qualified');
      } else {
        const needed = 3 - itemCount;
        offerStatus.textContent = `${itemCount}/3`;
        offerSubtext.textContent = `Füge ${needed} mehr hinzu für ein gratis Geschenk`;
        offerMessage.textContent = `Füge ${needed} mehr Artikel hinzu für ein gratis Geschenk`;
        offerBanner.classList.remove('qualified');
      }
    }

    // ===== FETCH CART AND UPDATE COUNT =====
    window.fetchCartAndUpdate = function() {
      return fetch('/cart.js')
        .then(response => response.json())
        .then(cart => {
          document.querySelectorAll('.cart-count, [data-cart-count]').forEach(el => {
            if (el) el.textContent = cart.item_count;
          });
          updateOfferDisplay(cart.item_count);
          return cart;
        })
        .catch(error => {
          console.error('Fehler beim Abrufen des Warenkorbs:', error);
          return { item_count: 0 };
        });
    };

    // ===== ADD TO CART - MODIFIED TO NOT CLOSE POPUP =====
    window.fcAddToCart = function(variantId) {
      const btn = event.target;
      const originalText = btn.innerText;
      const originalBackground = btn.style.background;
      
      btn.innerText = 'Wird hinzugefügt...';
      btn.disabled = true;
      
      console.log('Füge zum Warenkorb hinzu mit Variante:', variantId);
      
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ 
          id: variantId, 
          quantity: 1 
        })
      })
      .then(response => response.json())
      .then(data => {
        btn.innerText = '✓ Hinzugefügt!';
        btn.style.background = '#2E7D32';
        
        fetchCartAndUpdate().then(cart => {
          showNotification(`✓ Hinzugefügt! ${cart.item_count}/3 Artikel für gratis Geschenk`);
        });
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 2000);
      })
      .catch(error => {
        console.error('Fehler beim Hinzufügen zum Warenkorb:', error);
        btn.innerText = 'Fehler';
        btn.style.background = '#c62828';
        
        setTimeout(() => {
          btn.innerText = originalText;
          btn.style.background = originalBackground || '#C41E3A';
          btn.disabled = false;
        }, 1500);
      });
      
      // IMPORTANT: Prevent event propagation to keep popup open
      event.stopPropagation();
      return false;
    };

    // ===== VIEW DETAILS =====
    window.fcViewDetails = function(url) {
      window.location.href = url;
    };

    // ===== GO BACK =====
    window.fcGoBack = function() {
      currentView = 'search';
      if (currentSearchQuery.length >= 1) {
        performSearch(currentSearchQuery);
      } else {
        steps.style.display = 'block';
        content.innerHTML = '';
      }
    };

    // ===== PERFORM SEARCH =====
    function performSearch(query) {
      currentSearchQuery = query;
      content.innerHTML = '<div class="fc-loading">Suche läuft...</div>';
      
      setTimeout(() => {
        // Search in catalog with fuzzy matching
        const catalogResults = advancedCatalogSearch(query);
        
        // Search in your products with advanced fuzzy matching
        const yourResults = searchProducts(query);
        
        // Search in hardcoded products
        const hardcodedResults = searchHardcodedProducts(query);
        
        let html = '';
        
        // Track which products we've already shown by their number
        const shownNumbers = new Set();
        
        // ===== FIRST: SHOW CATALOG RESULTS (ECHTE PARFUMS) =====
        if (catalogResults.length > 0) {
          html += `<div class="fc-section-title">✨ Echte Parfums (${catalogResults.length})</div>`;
          
          catalogResults.slice(0, 8).forEach(perfume => {
            html += `
              <div class="fc-real-perfume-item" onclick="window.fcShowPerfumeDetail('${perfume.id}')">
                <img class="fc-real-perfume-image" src="${perfume.image}" 
                     alt="${perfume.name}" 
                     loading="lazy"
                     onerror="this.src='https://via.placeholder.com/60x60?text=Parfum'">
                <div class="fc-real-perfume-info">
                  <div class="fc-real-perfume-name">${perfume.name}</div>
                  <div class="fc-real-perfume-brand">${perfume.brand}</div>
                  ${perfume.year ? `<div class="fc-real-perfume-year">${perfume.year}</div>` : ''}
                </div>
              </div>
            `;
          });
        }
        
        // ===== SECOND: Show hardcoded results (these are the most accurate) =====
        if (hardcodedResults.length > 0) {
          html += `<div class="fc-section-title">🛍️ Unsere Kollektion (${hardcodedResults.length})</div>`;
          
          hardcodedResults.slice(0, 12).forEach(match => {
            const p = match.product;
            const priceFormatted = '€' + (p.price / 100).toFixed(2);
            
            // Track this product number
            if (p.number) {
              shownNumbers.add(p.number);
            }
            
            html += `
              <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
                <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy">
                <div class="fc-real-perfume-info">
                  <div class="fc-real-perfume-name">${p.title}</div>
                  <div class="fc-real-perfume-year">${priceFormatted}</div>
                </div>
              </div>
            `;
          });
        }
        
        // ===== THIRD: Then show your products (filter out duplicates) =====
        if (yourResults.length > 0) {
          const filteredYourResults = yourResults.filter(match => {
            const number = extractProductNumber(match.product.title);
            return !shownNumbers.has(number);
          });
          
          if (filteredYourResults.length > 0) {
            html += `<div class="fc-section-title">Unsere Produkte (${filteredYourResults.length})</div>`;
            
            filteredYourResults.slice(0, 6).forEach(match => {
              const p = match.product;
              const priceFormatted = p.price ? '€' + (p.price / 100).toFixed(2) : '€11.99';
              const number = extractProductNumber(p.title);
              
              if (number) shownNumbers.add(number);
              
              html += `
                <div class="fc-real-perfume-item" onclick="window.fcViewDetails('${p.url}')">
                  <img class="fc-real-perfume-image" src="${p.image}" alt="${p.title}" loading="lazy">
                  <div class="fc-real-perfume-info">
                    <div class="fc-real-perfume-name">${p.title}</div>
                    <div class="fc-real-perfume-year">${priceFormatted}</div>
                  </div>
                </div>
              `;
            });
          }
        }
        
        // If no results at all, show suggestions
        if (html === '') {
          html = '<div class="fc-no-results">Keine Produkte gefunden für "' + query + '"</div>';
          html += renderSuggestions();
        }
        
        content.innerHTML = html;
      }, 300);
    }

    // ===== SEARCH HANDLER =====
    function fcHandleSearch() {
      const query = searchInput.value.trim();
      
      if (query.length < 1) {
        if (currentView !== 'detail') {
          steps.style.display = 'block';
          content.innerHTML = '';
        }
        return;
      }
      
      steps.style.display = 'none';
      currentView = 'search';
      
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => performSearch(query), 300);
    }

    // ===== INITIALIZE =====
    // ===== INITIALIZE =====
    document.addEventListener('DOMContentLoaded', function() {
      try {
        // Verify all elements exist before proceeding
        if (!searchInput) {
          console.error('fcSearchInput element not found');
          return;
        }
        if (!clearSearch) {
          console.error('fcClearSearch element not found');
          return;
        }
        if (!searchPopup) {
          console.error('fcSearchPopup element not found');
          return;
        }
        if (!stickyButton) {
          console.error('fcStickyButton element not found');
          return;
        }
        if (!content) {
          console.error('fcContent element not found');
          return;
        }
        if (!steps) {
          console.error('fcSteps element not found');
          return;
        }
        
        fcInitProducts();
        combineCatalogs();
        
        // Add search event listener
        searchInput.addEventListener('keyup', fcHandleSearch);
        
        // Add clear search button listener
        clearSearch.addEventListener('click', function() {
          searchInput.value = '';
          searchInput.focus();
          if (steps) steps.style.display = 'block';
          if (content) content.innerHTML = '';
          currentView = 'search';
        });
        
        setTimeout(fetchCartAndUpdate, 500);
        
        // Close popup when clicking outside
        document.addEventListener('click', function(event) {
          if (searchPopup && stickyButton) {
            if (!searchPopup.contains(event.target) && !stickyButton.contains(event.target) && searchPopup.classList.contains('active')) {
              searchPopup.classList.remove('active');
            }
          }
        });
        
        // Close popup with Escape key
        document.addEventListener('keydown', function(e) {
          if (e.key === 'Escape' && searchPopup && searchPopup.classList.contains('active')) {
            searchPopup.classList.remove('active');
          }
        });
        
        // Prevent popup click from closing popup
        searchPopup.addEventListener('click', function(e) {
          e.stopPropagation();
        });
        
        console.log('✓ Fragrance Search initialized successfully');
      } catch (e) {
        console.error('Error initializing Fragrance Search:', e);
      }
    });
  })(); // Close and invoke IIFE
} catch (error) {
  console.error('Fragrance Search Error:', error);
}
</script>