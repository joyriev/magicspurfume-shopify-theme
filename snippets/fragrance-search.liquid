    // ===== SEARCH IN HARDCODED PRODUCTS =====
    function searchHardcodedProducts(query) {
      if (!query || query.length < 1) return [];
      
      const queryLower = query.toLowerCase().trim();
      const queryNoSpaces = queryLower.replace(/\s+/g, ''); // Remove all spaces for no-space matching
      const results = [];
      const addedIds = new Set();
      
      console.log('🔍 Suche in Hardcoded-Produkten für:', queryLower);
      
      hardcodedProducts.forEach(product => {
        if (addedIds.has(product.id)) return;
        
        let score = 0;
        let matchReasons = [];
        
        // Check title (highest priority)
        if (product.title.toLowerCase().includes(queryLower)) {
          score = Math.max(score, 100);
          matchReasons.push('hardcoded-titel');
        }
        // Check title without spaces
        if (product.title.toLowerCase().replace(/\s+/g, '').includes(queryNoSpaces) && queryNoSpaces.length > 2) {
          score = Math.max(score, 95);
          matchReasons.push('hardcoded-titel-nospaces');
        }
        
        // Check search terms (high priority) - including no-space versions
        if (product.searchTerms) {
          for (const term of product.searchTerms) {
            const termLower = term.toLowerCase();
            const termNoSpaces = termLower.replace(/\s+/g, '');
            
            // Exact space-preserved match
            if (termLower.includes(queryLower) || queryLower.includes(termLower)) {
              score = Math.max(score, 90);
              matchReasons.push('hardcoded-suchbegriff');
            }
            // No-space match (both query and term without spaces)
            if (termNoSpaces.includes(queryNoSpaces) || queryNoSpaces.includes(termNoSpaces)) {
              score = Math.max(score, 88);
              matchReasons.push('hardcoded-suchbegriff-nospaces');
            }
          }
        }
        
        // Check number (medium priority)
        if (product.number && queryLower.includes(product.number)) {
          score = Math.max(score, 95);
          matchReasons.push('hardcoded-nummer');
        }
        
        // Check brand (medium-high priority)
        if (product.brand.toLowerCase().includes(queryLower)) {
          score = Math.max(score, 85);
          matchReasons.push('hardcoded-marke');
        }
        // Brand without spaces
        if (product.brand.toLowerCase().replace(/\s+/g, '').includes(queryNoSpaces)) {
          score = Math.max(score, 82);
          matchReasons.push('hardcoded-marke-nospaces');
        }
        
        // BONUS: Boost men's products (gender "m") for certain searches
        if (product.gender === 'm' && (queryLower.includes('herren') || queryLower.includes('men') || queryLower.includes('male') || queryLower.includes('mann'))) {
          score += 15;
          matchReasons.push('gender-bonus-male');
        }
        
        if (score > 50) {
          results.push({ product, score: Math.round(score), matchReasons });
          addedIds.add(product.id);
          console.log(`✅ Hardcoded-Treffer: ${product.title} (Score: ${Math.round(score)})`);
        }
      });
      
      // Sort results by score (highest first)
      results.sort((a, b) => b.score - a.score);
      
      console.log(`📊 ${results.length} Hardcoded-Ergebnisse für "${query}" gefunden`);
      
      return results;
    }

    // ===== ADVANCED PRODUCT SEARCH WITH FUZZY MATCHING =====
    function searchProducts(query) {
      if (!query || query.length < 1 || !fcProducts || fcProducts.length === 0) {
        return [];
      }
      
      const queryLower = query.toLowerCase().trim();
      const results = [];
      const addedIds = new Set();
      
      console.log('🔍 Erweiterte Produktsuche für:', queryLower);
      
      // Handle brand-specific searches
      const brandMappings = {
        'dior': ['dior', 'dior parfum', 'dior sauvage', 'dior homme', 'j\'adore', 'jadore', 'poison'],
        'armani': ['armani', 'giorgio armani', 'armani code', 'acqua di gio', 'si', 'my way'],
        'chanel': ['chanel', 'bleu', 'coco', 'mademoiselle', 'chance', 'no5', 'allure'],
        'paco rabanne': ['paco rabanne', 'one million', 'invictus', 'phantom', 'lady million', 'fame', 'olympea'],
        'ysl': ['ysl', 'yves saint laurent', 'libre', 'black opium', 'opium'],
        'valentino': ['valentino', 'born in roma'],
        'jean paul gaultier': ['jean paul gaultier', 'scandal', 'le male', 'la belle', 'ultra male'],
        'tom ford': ['tom ford', 'lost cherry', 'tobacco vanille', 'oud wood'],
        'carolina herrera': ['carolina herrera', 'good girl'],
        'boss': ['hugo boss', 'boss bottled', 'boss'],
        'calvin klein': ['calvin klein', 'ck', 'eternity', 'euphoria', 'one'],
        'dolce': ['dolce', 'dolce & gabbana', 'd&g', 'light blue', 'the one']
      };
      
      // Check if query matches any brand
      let matchedBrands = [];
      for (const [brand, keywords] of Object.entries(brandMappings)) {
        if (keywords.some(keyword => queryLower.includes(keyword))) {
          matchedBrands.push(brand);
        }
      }
      
      fcProducts.forEach(product => {
        if (addedIds.has(product.id)) return;
        
        const title = product.title.toLowerCase();
        let bestScore = 0;
        let matchReasons = [];
        
        // Check for brand matches (highest priority)
        for (const brand of matchedBrands) {
          if (title.includes(brand)) {
            bestScore = Math.max(bestScore, 95);
            matchReasons.push(`brand-match:${brand}`);
          }
        }
        
        // Direct query match in title
        if (title.includes(queryLower)) {
          bestScore = Math.max(bestScore, 100);
          matchReasons.push('direct-match');
        }
        
        // Check product number
        const productNumber = extractProductNumber(product.title);
        if (productNumber && queryLower.includes(productNumber)) {
          bestScore = Math.max(bestScore, 150);
          matchReasons.push(`number-match:${productNumber}`);
        }
        
        // Check for individual words
        const queryWords = queryLower.split(' ').filter(w => w.length > 2);
        for (const word of queryWords) {
          if (title.includes(word)) {
            bestScore = Math.max(bestScore, 80);
            matchReasons.push(`word-match:${word}`);
          }
        }
        
        // Check brand in metafields
        const nuta = product.metafields?.custom?.nuta?.toLowerCase() || '';
        if (nuta) {
          if (nuta.includes(queryLower)) {
            bestScore = Math.max(bestScore, 90);
            matchReasons.push('nuta-match');
          } else {
            // Check if nuta contains any brand keywords
            for (const brand of matchedBrands) {
              if (nuta.includes(brand)) {
                bestScore = Math.max(bestScore, 85);
                matchReasons.push(`nuta-brand:${brand}`);
              }
            }
          }
        }
        
        // Check gender indicators if query contains gender terms
        if (queryLower.includes('damen') || queryLower.includes('frau') || queryLower.includes('herren') || queryLower.includes('mann')) {
          if (queryLower.includes('damen') || queryLower.includes('frau')) {
            if (title.includes('w)') || title.includes('-w') || title.includes('for her')) {
              bestScore += 10;
            }
          }
          if (queryLower.includes('herren') || queryLower.includes('mann')) {
            if (title.includes('m)') || title.includes('-m') || title.includes('for him')) {
              bestScore += 10;
            }
          }
        }
        
        if (bestScore > 30) {
          results.push({ 
            product, 
            score: Math.round(bestScore),
            matchReasons 
          });
          addedIds.add(product.id);
        }
      });
      
      // Sort by score (highest first)
      results.sort((a, b) => b.score - a.score);
      
      console.log(`📊 ${results.length} Produkt-Ergebnisse für "${query}" gefunden`);
      
      return results;
    }

    // ===== ADVANCED CATALOG SEARCH WITH FUZZY MATCHING =====
    function advancedCatalogSearch(query) {
      if (!query || query.length < 1 || !allPerfumes || allPerfumes.length === 0) {
        return [];
      }
      
      const queryLower = query.toLowerCase().trim();
      const results = [];
      const addedIds = new Set();
      
      console.log('🔍 Erweiterte Katalogs​​suche für:', queryLower);
      
      // Create variations of the search query
      const queryVariations = generateQueryVariations(queryLower);
      console.log('Katalog-Suchvariationen:', queryVariations);
      
      // Check ALL perfumes with advanced fuzzy matching
      allPerfumes.forEach(perfume => {
        if (addedIds.has(perfume.id)) return;
        
        const searchableText = [
          perfume.name || '',
          perfume.brand || '',
          perfume.gender || '',
          ...(perfume.top_notes || []),
          ...(perfume.heart_notes || []),
          ...(perfume.base_notes || []),
          ...(perfume.productNumbers || [])
        ].join(' ').toLowerCase();
        
        let bestScore = 0;
        let matchReasons = [];
        
        // Check each variation against the searchable text
        for (const variation of queryVariations) {
          // Direct contains match (highest score)
          if (searchableText.includes(variation)) {
            bestScore = Math.max(bestScore, 100);
            matchReasons.push(`direkt:${variation}`);
          }
        }
        
        // If no direct match, try advanced similarity on name and brand
        if (bestScore < 50) {
          const nameScore = calculateAdvancedSimilarity(queryLower, perfume.name || '');
          const brandScore = calculateAdvancedSimilarity(queryLower, perfume.brand || '');
          
          const combinedScore = Math.max(nameScore, brandScore);
          if (combinedScore > 40) {
            bestScore = Math.max(bestScore, combinedScore);
            if (nameScore > brandScore) {
              matchReasons.push(`name:${Math.round(nameScore)}%`);
            } else {
              matchReasons.push(`marke:${Math.round(brandScore)}%`);
            }
          }
        }
        
        // Check product numbers
        if (perfume.productNumbers) {
          for (const num of perfume.productNumbers) {
            if (queryLower.includes(num)) {
              bestScore = Math.max(bestScore, 150);
              matchReasons.push(`nummer:${num}`);
            }
          }
        }
        
        if (bestScore > 30) {
          results.push({ 
            perfume, 
            score: Math.round(bestScore),
            matchReasons 
          });
          addedIds.add(perfume.id);
          console.log(`✅ Katalog-Treffer: ${perfume.name} (Punktzahl: ${Math.round(bestScore)})`, matchReasons);
        }
      });
      
      // Sort by score (highest first)
      results.sort((a, b) => b.score - a.score);
      
      console.log(`📊 ${results.length} Katalog-Ergebnisse für "${query}" gefunden`);
      
      return results.map(r => r.perfume);
    }

