  // ===== SEARCH IN HARDCODED PRODUCTS =====
  function searchHardcodedProducts(query) {
    if (!query || query.length < 1) return [];
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    const addedIds = new Set();
    
    console.log('🔍 Suche in Hardcoded-Produkten für:', queryLower);
    
    hardcodedProducts.forEach(product => {
      // Check title
      if (product.title.toLowerCase().includes(queryLower)) {
        results.push({ product, score: 100, matchReasons: ['hardcoded-titel'] });
        addedIds.add(product.id);
        return;
      }
      
      // Check search terms
      if (product.searchTerms) {
        for (const term of product.searchTerms) {
          if (term.includes(queryLower) || queryLower.includes(term)) {
            results.push({ product, score: 90, matchReasons: ['hardcoded-suchbegriff'] });
            addedIds.add(product.id);
            return;
          }
        }
      }
      
      // Check number
      if (product.number && queryLower.includes(product.number)) {
        results.push({ product, score: 95, matchReasons: ['hardcoded-nummer'] });
        addedIds.add(product.id);
        return;
      }
      
      // Check brand
      if (product.brand.toLowerCase().includes(queryLower)) {
        results.push({ product, score: 85, matchReasons: ['hardcoded-marke'] });
        addedIds.add(product.id);
        return;
      }
    });
    
    return results;
  }

  // ===== ADVANCED PRODUCT SEARCH WITH FUZZY MATCHING =====
  function searchProducts(query) {
    if (!query || query.length < 1 || !fcProducts || fcProducts.length === 0) {
      return [];
    }
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    const addedIds = new Set();
    
    console.log('🔍 Erweiterte Produktsuche für:', queryLower);
    
    // FIRST: Special handling for "code"
    if (queryLower.includes('code')) {
      // Find No. 260 (men's)
      const no260 = fcProducts.find(p => 
        p.title.toLowerCase().includes('no. 260') || 
        p.title.toLowerCase().includes('no 260')
      );
      
      if (no260) {
        results.push({ product: no260, score: 1000 });
        addedIds.add(no260.id);
        console.log('✅ No. 260 für "code" gefunden');
      }
      
      // Find No. 135 (women's)
      const no135 = fcProducts.find(p => 
        p.title.toLowerCase().includes('no. 135') || 
        p.title.toLowerCase().includes('no 135')
      );
      
      if (no135 && !addedIds.has(no135.id)) {
        results.push({ product: no135, score: 900 });
        addedIds.add(no135.id);
        console.log('✅ No. 135 für "code" gefunden');
      }
    }
    
    // SECOND: Special handling for Paco Rabanne products
    const pacoKeywords = ['million', 'lucky', 'lady', 'fame', 'invictus', 'phantom', 'victory', 'olympea', 'ultraviolet', 'pure xs'];
    for (const keyword of pacoKeywords) {
      if (queryLower.includes(keyword)) {
        const pacoProduct = fcProducts.find(p => 
          p.title.toLowerCase().includes(keyword) || 
          p.title.toLowerCase().includes('paco rabanne')
        );
        
        if (pacoProduct && !addedIds.has(pacoProduct.id)) {
          results.push({ product: pacoProduct, score: 950 });
          addedIds.add(pacoProduct.id);
          console.log(`✅ Paco Rabanne Produkt für "${keyword}" gefunden`);
        }
      }
    }
    
    // THIRD: Special handling for "one million lucky"
    if (queryLower.includes('one million lucky') || 
        queryLower.includes('million lucky') || 
        (queryLower.includes('one million') && queryLower.includes('lucky'))) {
      
      const oneMillionLucky = fcProducts.find(p => 
        p.title.toLowerCase().includes('one million lucky') ||
        p.title.includes('No. 280') ||
        p.title.includes('No.280')
      );
      
      if (oneMillionLucky && !addedIds.has(oneMillionLucky.id)) {
        results.push({ product: oneMillionLucky, score: 1000 });
        addedIds.add(oneMillionLucky.id);
        console.log('✅ One Million Lucky DIREKT gefunden');
      }
    }
    
    // Create variations of the search query for better matching
    const queryVariations = generateQueryVariations(queryLower);
    console.log('Produkt-Suchvariationen:', queryVariations);
    
    // Check ALL products with advanced fuzzy matching
    fcProducts.forEach(product => {
      if (addedIds.has(product.id)) return;
      
      const title = product.title;
      const titleLower = title.toLowerCase();
      let bestScore = 0;
      let matchReasons = [];
      
      // Check each variation against the title
      for (const variation of queryVariations) {
        // Direct contains match (highest score)
        if (titleLower.includes(variation)) {
          bestScore = Math.max(bestScore, 100);
          matchReasons.push(`direkt:${variation}`);
        }
      }
      
      // If no direct match, try advanced similarity
      if (bestScore < 50) {
        const similarityScore = calculateAdvancedSimilarity(queryLower, titleLower);
        if (similarityScore > 40) { // 40% similarity threshold
          bestScore = Math.max(bestScore, similarityScore);
          matchReasons.push(`unscharf:${Math.round(similarityScore)}%`);
        }
      }
      
      // Check for number matches (always exact)
      const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
      if (numberMatch && queryLower.includes(numberMatch[1])) {
        bestScore = Math.max(bestScore, 150);
        matchReasons.push(`nummer:${numberMatch[1]}`);
      }
      
      // Check brand name in metafields
      const nuta = product.metafields?.custom?.nuta?.toLowerCase() || '';
      if (nuta) {
        const brandScore = calculateAdvancedSimilarity(queryLower, nuta);
        if (brandScore > 50) {
          bestScore = Math.max(bestScore, brandScore * 0.8);
          matchReasons.push(`marke:${Math.round(brandScore)}%`);
        }
      }
      
      if (bestScore > 30) {
        results.push({ 
          product, 
          score: Math.round(bestScore),
          matchReasons 
        });
        addedIds.add(product.id);
        console.log(`✅ Produkt-Treffer: ${product.title} (Punktzahl: ${Math.round(bestScore)})`, matchReasons);
      }
    });
    
    // Sort by score (highest first)
    results.sort((a, b) => b.score - a.score);
    
    console.log(`📊 ${results.length} Produkt-Ergebnisse für "${query}" gefunden`);
    if (results.length > 0) {
      console.log('🏆 Top-Produkt:', results[0].product.title, 'Punktzahl:', results[0].score);
    }
    
    return results;
  }

  // ===== ADVANCED CATALOG SEARCH WITH FUZZY MATCHING =====
  function advancedCatalogSearch(query) {
    if (!query || query.length < 1 || !allPerfumes || allPerfumes.length === 0) {
      return [];
    }
    
    const queryLower = query.toLowerCase().trim();
    const results = [];
    const addedIds = new Set();
    
    console.log('🔍 Erweiterte Katalogs​​suche für:', queryLower);
    
    // Create variations of the search query
    const queryVariations = generateQueryVariations(queryLower);
    console.log('Katalog-Suchvariationen:', queryVariations);
    
    // Check ALL perfumes with advanced fuzzy matching
    allPerfumes.forEach(perfume => {
      if (addedIds.has(perfume.id)) return;
      
      const searchableText = [
        perfume.name || '',
        perfume.brand || '',
        perfume.gender || '',
        ...(perfume.top_notes || []),
        ...(perfume.heart_notes || []),
        ...(perfume.base_notes || []),
        ...(perfume.productNumbers || [])
      ].join(' ').toLowerCase();
      
      let bestScore = 0;
      let matchReasons = [];
      
      // Check each variation against the searchable text
      for (const variation of queryVariations) {
        // Direct contains match (highest score)
        if (searchableText.includes(variation)) {
          bestScore = Math.max(bestScore, 100);
          matchReasons.push(`direkt:${variation}`);
        }
      }
      
      // If no direct match, try advanced similarity on name and brand
      if (bestScore < 50) {
        const nameScore = calculateAdvancedSimilarity(queryLower, perfume.name || '');
        const brandScore = calculateAdvancedSimilarity(queryLower, perfume.brand || '');
        
        const combinedScore = Math.max(nameScore, brandScore);
        if (combinedScore > 40) {
          bestScore = Math.max(bestScore, combinedScore);
          if (nameScore > brandScore) {
            matchReasons.push(`name:${Math.round(nameScore)}%`);
          } else {
            matchReasons.push(`marke:${Math.round(brandScore)}%`);
          }
        }
      }
      
      // Check product numbers
      if (perfume.productNumbers) {
        for (const num of perfume.productNumbers) {
          if (queryLower.includes(num)) {
            bestScore = Math.max(bestScore, 150);
            matchReasons.push(`nummer:${num}`);
          }
        }
      }
      
      if (bestScore > 30) {
        results.push({ 
          perfume, 
          score: Math.round(bestScore),
          matchReasons 
        });
        addedIds.add(perfume.id);
        console.log(`✅ Katalog-Treffer: ${perfume.name} (Punktzahl: ${Math.round(bestScore)})`, matchReasons);
      }
    });
    
    // Sort by score (highest first)
    results.sort((a, b) => b.score - a.score);
    
    console.log(`📊 ${results.length} Katalog-Ergebnisse für "${query}" gefunden`);
    
    return results.map(r => r.perfume);
  }

