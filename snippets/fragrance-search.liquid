  // ===== RENDER PRODUCT CARD WITH NUMERIC VARIANT ID =====
  function renderProductCard(product, badge) {
    const priceFormatted = product.price ? '€' + (product.price / 100).toFixed(2) : '€11.99';
    
    let displayNumber = '';
    let displayName = product.title;
    
    const numberMatch = product.title.match(/No\.?\s*(\d+)/i);
    if (numberMatch) {
      displayNumber = numberMatch[0];
    }
    
    const inspiredMatch = product.title.match(/Riecht wie\.\.\. (.*)/i);
    if (inspiredMatch) {
      displayName = inspiredMatch[1];
    }
    
    // Use the numeric variant ID (NOT the SKU)
    const variantId = product.variant;
    
    return `
      <div class="fc-product-card">
        <div class="fc-badge">${badge}</div>
        <div class="fc-product-inner">
          <img class="fc-product-image" src="${product.image}" alt="${product.title}" loading="lazy">
          <div class="fc-product-title">${displayNumber ? displayNumber + ' - ' : ''}${displayName}</div>
          <div class="fc-product-price">${priceFormatted}</div>
          <button class="fc-add-to-cart" onclick="event.stopPropagation(); window.fcAddToCart(${variantId})">In den Warenkorb</button>
          <div>
            <span class="fc-view-link" onclick="event.stopPropagation(); window.fcViewDetails('${product.url}')">Details ansehen</span>
          </div>
        </div>
      </div>
    `;
  }

