<style>
  .swiper-button-next::after,
  .swiper-button-prev::after {
    font-size: 12px !important;
    color: #000 !important;
  }
</style>

{% if product.metafields.custom.similar_scents != blank %}
  <p class="text-base font-serif leading-tight">Parfüms mit ähnlichen Duftnoten:</p>
  {% assign similar_scents = product.metafields.custom.similar_scents.value %}
  <div class="swiper slider-{{ section.id }}-{{ forloop.index }}">
    <div class="swiper-wrapper">
      {% for similar_scent in similar_scents %}
        <div class="swiper-slide">
          <div class="flex gap-2 items-center p-3 bg-white rounded-lg">
            <img
              class="object-cover border border-solid border-gray-200"
              height="60"
              width="60"
              src="{{ similar_scent.image | image_url: width: 100 }}"
              alt="{{ similar_scent.title }}">
            <div class="text-left">
              <div class="text-sm font-semibold text-black line-clamp-1">
                {{ similar_scent.title }}
              </div>
              <div class="text-sm text-gray-600 my-1">
                {{ similar_scent.price.value | money }}
              </div>
              <div class="text-[10px] leading-none {% if similar_scent.similarity == 'Ähnliche Notizen' %}text-green-600{% else %} text-yellow-600 {% endif %}">
                {{ similar_scent.similarity }}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <button class="swiper-button-next p-0 !size-7 !right-0 rounded-full border border-solid !border-gray-200 bg-white/60 filter backdrop-blur-sm"></button>
    <button class="swiper-button-prev p-0 !size-7 !left-0 rounded-full border border-solid !border-gray-200 bg-white/60 filter backdrop-blur-sm"></button>
  </div>
  <script>
      document.addEventListener('DOMContentLoaded', function() {
          new Swiper('.slider-{{ section.id }}-{{ forloop.index }}', {
              slidesPerView: 1,
              spaceBetween: 10,
              loop: true,
              breakpoints: {
                  640: {
                      slidesPerView: 2,
                      spaceBetween: 10,
                  }
              },
              navigation: {
                  nextEl: '.swiper-button-next',
                  prevEl: '.swiper-button-prev',
              },
          });
      });
  </script>
{% endif %}

{% liquid
  assign product_form_id = 'product-form-' | append: section.id
  assign selected_variant = product.selected_or_first_available_variant
  assign selling_points = product.metafields.custom.bullets.value
%}

{% if selling_points %}
  <ul id="atc_scroll_target" class="list-none pl-0">
    {% for point in selling_points %}
      {% assign point_value = point | replace: '✅', '' %}
      <li>✅ {{ point_value }}</li>
    {% endfor %}
  </ul>
{% endif %}

<div
  class="!mt-8 !mb-6 flex gap-2 items-end"
  id="product-price"
  role="status">
  {% if selected_variant.compare_at_price > selected_variant.price %}
    <span class="compare-price line-through text-base">{{ selected_variant.compare_at_price | money }}</span>
  {% endif %}
  <span class="current-price text-black font-black text-3xl">{{ selected_variant.price | money }}</span>
  <span class="text-sm text-gray-400">inkl. MwSt.</span>
</div>

{% if product.variants.size > 1 %}
  {% comment %} Variant Selector {% endcomment %}
  <h2 class="m-0 text-sm text-gray-400 tracking-wide font-normal">GRÖSSENAUSWAHL:</h2>
  <div class="flex gap-3" id="variant-selector">
    {% for variant in product.variants %}
      <button
        type="button"
        class="variant-button flex md:flex-col items-center gap-2 rounded-lg px-5 flex-grow pt-5 pb-4 bg-white border-2 border-solid cursor-pointer font-['Plus_Jakarta_Sans'] relative {% if variant.id == selected_variant.id %}border-black{% else %}border-gray-200{% endif %}"
        data-variant-id="{{ variant.id }}"
        data-variant-title="{{ variant.title }}"
        data-original-price="{{ variant.price | money }}"
        data-compare-price="{{ variant.compare_at_price | money }}">
        <div class="text-center">
          <div class="text-base font-semibold">{{ variant.title }}</div>
        </div>
        {% if variant.title == '50ml' %}
          <span class="text-xs italic text-white rounded absolute -top-2.5 left-1/2 [transform:translateX(-50%)] bg-[#c8202f] px-2 py-0.5">Beliebt</span>
        {% endif %}
        {% if variant.title == '100ml' %}
          <span class="text-xs italic text-white rounded absolute -top-2.5 left-1/2 [transform:translateX(-50%)] bg-[#22613a] px-2 py-0.5">Bestseller</span>
        {% endif %}
      </button>
    {% endfor %}
  </div>
{% endif %}

{% comment %} Add to cart form {% endcomment %}
<product-form
  class="product-form !m-0"
  data-hide-errors="{{ gift_card_recipient_feature_active }}"
  data-section-id="{{ section.id }}">
  {%- form 'product'
    , product
    , id: product_form_id
    , class: 'form'
    , novalidate: 'novalidate'
    , data-type: 'add-to-cart-form'
  -%}
    <input
      type="hidden"
      name="id"
      id="product-variant-id"
      value="{{ selected_variant.id }}"
      class="product-variant-id">
    <button
      type="submit"
      name="add"
      value="1"
      class="atc-button cta_product_from_submit_btn flex flex-wrap items-center gap-4 !mb-0 text-xl !py-4 rounded-lg button bg-black transition-colors shadow-xl tracking-normal uppercase button--full-width button--primary"
      aria-label="Add to cart"
      {% if product.metafields.custom.choose_your_fragrances_options != blank %}
      disabled="disabled"
      {% endif %}>
      <svg
        width="18"
        height="22"
        viewBox="0 0 18 22"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M5.14647 8.25221V5.52404C5.14647 3.02159 6.87039 1 8.99598 1C11.1216 1 12.8539 3.02159 12.8539 5.52404V8.25221M16.988 18.5074L16.4356 8.26202C16.3687 7.02552 15.4816 6.06379 14.4104 6.06379H3.58155C2.51037 6.06379 1.62331 7.02552 1.55636 8.26202L1.00403 18.5074C0.928716 19.8518 1.85763 21 3.02922 21H14.9711C16.1427 21 17.0633 19.8616 16.9963 18.5074H16.988Z"
          stroke="white"
          stroke-width="2"
          stroke-miterlimit="10"
          stroke-linecap="round" />
      </svg>
      <span>In den Warenkorb</span>
      {%- render 'loading-spinner' -%}
    </button>
  {%- endform -%}
</product-form>

<script>
    (function() {
  // Variant data object
  const variantsData = {
    {% for variant in product.variants %}
      "{{ variant.id }}": {
        title: "{{ variant.title }}",
        originalPrice: "{{ variant.price | money }}",
        compareAtPrice: "{{ variant.compare_at_price | money }}",
        hasComparePrice: {% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  // State
  let selectedVariantId = "{{ selected_variant.id }}";

  // DOM elements
  const variantButtons = document.querySelectorAll('.variant-button');
  const variantIdInput = document.getElementById('product-variant-id');
  const priceContainer = document.getElementById('product-price');
  const comparePriceSpan = priceContainer.querySelector('.compare-price');
  const currentPriceSpan = priceContainer.querySelector('.current-price');

  // Update variant selection
  function updateVariant(variantId) {
    selectedVariantId = variantId;
    const variantData = variantsData[variantId];

    // Update hidden input
    variantIdInput.value = variantId;

    // Update button styles
    variantButtons.forEach(button => {
      if (button.dataset.variantId === variantId) {
        button.classList.add('border-black');
        button.classList.remove('border-gray-200');
      } else {
        button.classList.remove('border-black');
        button.classList.add('border-gray-200');
      }
    });

    // Update price display
    if (variantData.hasComparePrice) {
      if (!comparePriceSpan) {
        const newCompareSpan = document.createElement('span');
        newCompareSpan.className = 'compare-price line-through text-white/50 text-base';
        priceContainer.insertBefore(newCompareSpan, currentPriceSpan);
      }
      const compareSpan = priceContainer.querySelector('.compare-price');
      compareSpan.innerHTML = variantData.compareAtPrice;
      compareSpan.style.display = '';
    } else {
      if (comparePriceSpan) {
        comparePriceSpan.style.display = 'none';
      }
    }

    currentPriceSpan.innerHTML = variantData.originalPrice;

    // Update all other current-price elements in page
    const allCurrentPriceElements = document.querySelectorAll('.current-price');
    allCurrentPriceElements.forEach(element => {
      // Skip the main price container element that we already updated
      if (element !== currentPriceSpan && element.textContent.trim() !== '') {
        element.innerHTML = variantData.originalPrice;
      }
    });
  }

  // Add click event listeners to variant buttons
  variantButtons.forEach(button => {
    button.addEventListener('click', function() {
      const variantId = this.dataset.variantId;
      updateVariant(variantId);
    });
  });
    })();
</script>

<style>
  .animate-ping-large {
    animation: ping-large 1.5s ease-in-out infinite;
  }

  @keyframes ping-large {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 1);
    }
    60% {
      box-shadow: 0 0 0 5px rgba(34, 197, 94, 0);
    }
    100% {
      box-shadow: 0 0 0 5px rgba(34, 197, 94, 0);
    }
  }
</style>

{% assign future_date = 'now' | date: '%s' | plus: 432000 %}

{% assign weekday_en = future_date | date: "%A" %}
{% assign month_en = future_date | date: "%B" %}
{% assign day = future_date | date: "%d" %}

{% case weekday_en %}
  {% when "Monday" %}
    {% assign weekday = "Montag" %}
  {% when "Tuesday" %}
    {% assign weekday = "Dienstag" %}
  {% when "Wednesday" %}
    {% assign weekday = "Mittwoch" %}
  {% when "Thursday" %}
    {% assign weekday = "Donnerstag" %}
  {% when "Friday" %}
    {% assign weekday = "Freitag" %}
  {% when "Saturday" %}
    {% assign weekday = "Samstag" %}
  {% when "Sunday" %}
    {% assign weekday = "Sonntag" %}
{% endcase %}

{% case month_en %}
  {% when "January" %}
    {% assign month = "Januar" %}
  {% when "February" %}
    {% assign month = "Februar" %}
  {% when "March" %}
    {% assign month = "März" %}
  {% when "April" %}
    {% assign month = "April" %}
  {% when "May" %}
    {% assign month = "Mai" %}
  {% when "June" %}
    {% assign month = "Juni" %}
  {% when "July" %}
    {% assign month = "Juli" %}
  {% when "August" %}
    {% assign month = "August" %}
  {% when "September" %}
    {% assign month = "September" %}
  {% when "October" %}
    {% assign month = "Oktober" %}
  {% when "November" %}
    {% assign month = "November" %}
  {% when "December" %}
    {% assign month = "Dezember" %}
{% endcase %}

<div class="!my-6 flex justify-center items-center gap-3">
  <span class="size-3 bg-green-600 rounded-full animate-ping-large shrink-0"></span>
  <span class="leading-snug">
    Blicke auf sich ziehen – ab
    <span class="text-white bg-green-700 rounded inline-block p-1 leading-none">
      {{ weekday }}, {{ day }} {{ month }}
    </span>
    bei dir.
  </span>
</div>

<div class="my-6">
  <div class="flex items-center gap-3 text-base">
    <img
      src="https://cdn.shopify.com/s/files/1/0623/0691/0402/files/thimbs_up.png?v=1751372431"
      alt="Thumbs up badge"
      class="w-10 h-10 flex-shrink-0"
      width="40"
      height="40" />
    <div class="text-slate-900">
      <strong class="font-semibold">Teste es 60 Tage lang – völlig risikofrei.</strong>
      <div class="[display:none] md:block">Sollten Sie nicht absolut begeistert sein, erstatten wir Ihnen den vollen Betrag zurück!</div>
    </div>
  </div>
</div>