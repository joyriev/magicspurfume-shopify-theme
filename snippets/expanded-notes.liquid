<div class="product__accordion accordion quick-add-hidden">
  <details id="Details-collapsible_tab_FAAFhb-template--22305367884034__main">
    <summary
      role="button"
      aria-expanded="false"
      aria-controls="ProductAccordion-collapsible_tab_FAAFhb-template--22305367884034__main"
    >
      <div class="summary__title">
        <h2 class="h4 accordion__title inline-richtext">Duftnoten</h2>
      </div>
      <svg
        aria-hidden="true"
        focusable="false"
        class="icon icon-caret"
        viewBox="0 0 10 6"
      >
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z"
          fill="currentColor"
        ></path>
      </svg>
    </summary>

    <div
      class="accordion__content rte"
      id="ProductAccordion-collapsible_tab_FAAFhb-template--22305367884034__main"
    >
      <div class="scent-notes-panel text-gray-800">
        <div class="mb-5">
          <p class="text-xs text-gray-500 mb-3 m-0">Hauptnoten:</p>
          <div class="flex flex-wrap gap-x-6">
            {% for note in product.metafields.custom.main_notes.value %}
              <figure class="m-0 flex flex-col items-center text-center">
                <div class="h-16 mb-2 flex items-end justify-center">
                  <img
                    class="!border-0 [filter:grayscale(100%)]"
                    src="{{ note.icon | image_url: width: 64 }}"
                    alt="{{ note.name }}"
                    width="34"
                    height="34"
                  >
                </div>
                <figcaption class="text-sm m-0">{{ note.name }}</figcaption>
              </figure>
            {% endfor %}
          </div>
        </div>

        <hr class="border-0 border-b border-solid border-gray-200 my-4">

        <div class="space-y-3">
          {% for note in product.metafields.custom.top_notes.value %}
            <div class="flex items-start gap-3">
              <svg
                width="20"
                height="28"
                viewBox="0 0 20 28"
                class="text-gray-700 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                <path d="M7 5 h6 v2 h-6 z"></path>
                <rect x="4" y="7" width="12" height="18" rx="2"></rect>
              </svg>
              <div class="min-w-0">
                <p class="text-sm m-0">
                  <strong class="font-bold">Kopfnoten:</strong>
                  {{ note.heading }}
                </p>
                <p class="text-sm text-gray-700 m-0">
                  {{ note.description | metafield_text }}
                </p>
              </div>
            </div>
          {% endfor %}

          {% for note in product.metafields.custom.middle_notes.value %}
            <div class="flex items-start gap-3">
              <svg
                width="20"
                height="28"
                viewBox="0 0 20 28"
                class="text-gray-700 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                <path d="M7 5 h6 v2 h-6 z"></path>
                <rect x="4" y="7" width="12" height="18" rx="2"></rect>
                <rect
                  x="4"
                  y="14"
                  width="12"
                  height="11"
                  rx="2"
                  fill="currentColor"
                  fill-opacity="0.2"
                ></rect>
              </svg>
              <div class="min-w-0">
                <p class="text-sm m-0">
                  <strong class="font-bold">Herznoten:</strong>
                  {{ note.heading }}
                </p>
                <p class="text-sm text-gray-700 m-0">
                  {{ note.description | metafield_text }}
                </p>
              </div>
            </div>
          {% endfor %}

          {% for note in product.metafields.custom.base_notes.value %}
            <div class="flex items-start gap-3">
              <svg
                width="20"
                height="28"
                viewBox="0 0 20 28"
                class="text-gray-700 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                <path d="M7 5 h6 v2 h-6 z"></path>
                <rect x="4" y="7" width="12" height="18" rx="2"></rect>
                <rect
                  x="4"
                  y="7"
                  width="12"
                  height="18"
                  rx="2"
                  fill="currentColor"
                  fill-opacity="0.35"
                ></rect>
              </svg>
              <div class="min-w-0">
                <p class="text-sm m-0">
                  <strong class="font-bold">Basisnoten:</strong>
                  {{ note.heading }}
                </p>
                <p class="text-sm text-gray-700 m-0">
                  {{ note.description | metafield_text }}
                </p>
              </div>
            </div>
          {% endfor %}
        </div>

        <hr class="border-0 border-b border-solid border-gray-200 my-4">

        <p class="text-xs leading-relaxed text-gray-700 mb-4 m-0">
          <strong class="font-bold">Inhaltsstoffe:</strong>
          {% if product.metafields.custom.ingredients.value != blank %}
            {{ product.metafields.custom.ingredients.value | metafield_text }}
          {% else %}
            Vergällter Alkohol, Duftstoff, Wasser, Limonen, Linalool,
            Citronellol, Geraniol, Citral, Benzylsalicylat, Cumarin,
            Alpha-Isomethylionon, Hexylcinnamal, Benzylbenzoat.
          {% endif %}
        </p>

        <div class="flex flex-wrap gap-2 mt-4">
          <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
            <svg
              class="w-3.5 h-3.5 mr-1.5 text-green-700"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M10 2 C7 5 4 8 4 12 C4 16 7 18 10 18 C13 18 16 16 16 12 C16 8 13 5 10 2 Z"></path>
            </svg>
            Vegan
          </span>

          <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
            Tierversuchsfrei
            <svg
              class="w-4 h-4 ml-1.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              aria-hidden="true"
            >
              <circle cx="12" cy="13" r="5"></circle>
              <ellipse cx="8" cy="7" rx="1.6" ry="2.4"></ellipse>
              <ellipse cx="16" cy="7" rx="1.6" ry="2.4"></ellipse>
              <ellipse cx="5" cy="11" rx="1.4" ry="1.8"></ellipse>
              <ellipse cx="19" cy="11" rx="1.4" ry="1.8"></ellipse>
            </svg>
          </span>

          <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
            <svg
              class="w-3.5 h-3.5 mr-1.5 text-green-700"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path d="M5 10 l3 3 l7-7"></path>
            </svg>
            Reine Inhaltsstoffe
          </span>
        </div>
      </div>
    </div>
  </details>
</div>
