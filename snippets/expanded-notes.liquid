                    <h2 class="h4 accordion__title inline-richtext font-bold tracking-normal text-sm md:text-base">
                        Duftnoten
                    </h2>
                </div>
                <div class="svg-wrapper bg-black text-white !size-6 p-1 rounded-full !mr-0 flex items-center justify-center"><svg xmlns="http://www.w3.org/2000/svg" fill="none" class="icon icon-plus" viewBox="0 0 10 10"><path fill="currentColor" fill-rule="evenodd" d="M1 4.51a.5.5 0 0 0 0 1h3.5l.01 3.5a.5.5 0 0 0 1-.01V5.5l3.5-.01a.5.5 0 0 0-.01-1H5.5L5.49.99a.5.5 0 0 0-1 .01v3.5l-3.5.01z" clip-rule="evenodd"></path></svg>
            </div>
        </summary>
        <div class="accordion__content rte" id="ProductAccordion-collapsible_tab_XYmgtQ-template--20437930934342__main">
            <div class="scent-notes-panel font-['Figtree'] text-gray-800">
                <div class="mb-5">
                    <p class="text-xs text-gray-500 mb-3 m-0">Hauptnoten:</p>
                    <div class="flex flex-wrap gap-6">
                        {% for note in product.metafields.custom.main_notes.value %}
                            <figure class="m-0 flex flex-col items-center text-center">
                                <div class="h-16 mb-2 flex items-end justify-center">
                                <img class="!border-0 [filter:grayscale(100%)]" src="{{ note.icon |  image_url: width: 64 }}" alt="{{ note.name }}" width="34" height="34">
                                </div>
                                <figcaption class="text-sm m-0">{{ note.name }}</figcaption>
                            </figure>
                        {% endfor %}
                    </div>
                </div>

                <hr class="border-0 border-b border-solid border-gray-200 my-4">

                <div class="space-y-3">
                    <div class="flex items-start gap-3">
                    <svg width="20" height="28" viewBox="0 0 20 28" class="text-gray-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                        <path d="M7 5 h6 v2 h-6 z"></path>
                        <rect x="4" y="7" width="12" height="18" rx="2"></rect>
                    </svg>
                    <div class="min-w-0">
                        <p class="text-sm m-0"><strong class="font-bold">Kopfnoten:</strong> {{ product.metafields.custom.top_notes.value.heading }}</p>
                        <p class="text-sm text-gray-700 m-0">{{ product.metafields.custom.top_notes.value.description | metafield_text }}</p>
                    </div>
                    </div>

                    <div class="flex items-start gap-3">
                    <svg width="20" height="28" viewBox="0 0 20 28" class="text-gray-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                        <path d="M7 5 h6 v2 h-6 z"></path>
                        <rect x="4" y="7" width="12" height="18" rx="2"></rect>
                        <rect x="4" y="14" width="12" height="11" rx="2" fill="currentColor" fill-opacity="0.2"></rect>
                    </svg>
                    <div class="min-w-0">
                        <p class="text-sm m-0"><strong class="font-bold">Herznoten:</strong> {{ product.metafields.custom.middle_notes.value.heading }}</p>
                        <p class="text-sm text-gray-700 m-0">{{ product.metafields.custom.middle_notes.value.description | metafield_text }}</p>
                    </div>
                    </div>

                    <div class="flex items-start gap-3">
                    <svg width="20" height="28" viewBox="0 0 20 28" class="text-gray-700 shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <rect x="8" y="2" width="4" height="3" rx="0.5"></rect>
                        <path d="M7 5 h6 v2 h-6 z"></path>
                        <rect x="4" y="7" width="12" height="18" rx="2"></rect>
                        <rect x="4" y="7" width="12" height="18" rx="2" fill="currentColor" fill-opacity="0.35"></rect>
                    </svg>
                    <div class="min-w-0">
                        <p class="text-sm m-0"><strong class="font-bold">Basisnoten:</strong> {{ product.metafields.custom.base_notes.value.heading }}</p>
                        <p class="text-sm text-gray-700 m-0">{{ product.metafields.custom.base_notes.value.description | metafield_text }}</p>
                    </div>
                    </div>
                </div>

                <hr class="border-0 border-b border-solid border-gray-200 my-4">

                {% if product.metafields.custom.ingredients.value != blank %}
                    <p class="text-xs leading-relaxed text-gray-700 mb-4 m-0">
                        <strong class="font-bold">Inhaltsstoffe:</strong>
                        {{ product.metafields.custom.ingredients.value | metafield_text }}
                    </p>
                {% endif %}

                <div class="flex flex-wrap gap-2 mt-4">
                    <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
                    <svg class="w-3.5 h-3.5 mr-1.5 text-green-700" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path d="M10 2 C7 5 4 8 4 12 C4 16 7 18 10 18 C13 18 16 16 16 12 C16 8 13 5 10 2 Z"></path>
                    </svg>
                    Vegan
                    </span>
                    <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
                    Tierversuchsfrei
                    <svg class="w-4 h-4 ml-1.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
                        <circle cx="12" cy="13" r="5"></circle>
                        <ellipse cx="8" cy="7" rx="1.6" ry="2.4"></ellipse>
                        <ellipse cx="16" cy="7" rx="1.6" ry="2.4"></ellipse>
                        <ellipse cx="5" cy="11" rx="1.4" ry="1.8"></ellipse>
                        <ellipse cx="19" cy="11" rx="1.4" ry="1.8"></ellipse>
                    </svg>
                    </span>
                    <span class="inline-flex items-center whitespace-nowrap px-3 py-1.5 rounded-full bg-white border border-solid border-gray-200 text-xs text-gray-800">
                    <svg class="w-3.5 h-3.5 mr-1.5 text-green-700" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M5 10 l3 3 l7-7"></path>
                    </svg>
                    Reine Inhaltsstoffe
                    </span>
                </div>
            </div>
        </div>
    </details>
</div>
