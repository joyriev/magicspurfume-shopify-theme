    "massive_review_x3kr6P": {
      "type": "massive-review",
      "blocks": {
        "review_YE8xbk": {
          "type": "review",
          "settings": {
            "content": "<p>„Das war meine erste Bestellung hier und ich bin echt begeistert. Ich kauf mein Parfüm ab jetzt nirgendwo anders mehr. Ich hab vorher nie einen Duft-Dupe gefunden, der wirklich authentisch riecht und dabei auch konstant gleich gut bleibt.“</p>",
            "author": "Sebastian Müller",
            "date": "vor 1 Tag",
            "rating": 5,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_pjzVtk": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/magic_ugc_female_01.webp",
            "content": "<p>„Ehrlich, einer der besten Düfte, die ich seit Jahren gerochen habe. Die Noten sind einfach brutal gut. Der bleibt definitiv dauerhaft in meiner Sammlung.“</p>",
            "author": "Emilia Wagner",
            "author_image": "shopify://shop_images/magic_ugc_female_01.webp",
            "date": "vor 2 Tagen",
            "rating": 4,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_cCdWNE": {
          "type": "review",
          "settings": {
            "content": "<p>„Alle drei Düfte, die ich bestellt habe, riechen echt richtig gut und halten auch lange. Die Düfte sind wirklich nah an den Originalen. Das Einzige war die Lieferzeit, die etwas länger gedauert hat. Aber ganz ehrlich – ich hab trotzdem direkt nochmal bestellt 😄 Man muss nur ein bisschen Geduld haben.“</p>",
            "author": "Clara P.",
            "date": "vor 2 Tagen",
            "rating": 5,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_mVXcif": {
          "type": "review",
          "settings": {
            "content": "<p>„Ich hab ewig nach Düften gesucht, die hochwertig riechen und auch lange halten. Genau so einen Duft hab ich gesucht.“</p>",
            "author": "Daniel Roth",
            "date": "vor 2 Tagen",
            "rating": 4,
            "show_verified_badge": true,
            "product": ""
          }
        },
        "review_mVgcRB": {
          "type": "review",
          "settings": {
            "review_image": "shopify://shop_images/magic_ugc_male_02.webp",
            "content": "<p>„Wusste erst nicht genau, was mich erwartet, aber der Duft hat mich echt positiv überrascht. Riecht super frisch und kommt Aventus ziemlich nah. Hält ordentlich und der Preis ist einfach deutlich besser.“</p>",
