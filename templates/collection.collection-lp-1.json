        "custom_liquid": "<style>\n#mp-reviews-custom{\n  padding:30px 0;\n  background:linear-gradient(180deg,#fff,#faf7f1);\n  overflow:hidden;\n}\n#mp-reviews-custom .mp-container{\n  width:min(1180px,calc(100% - 36px));\n  margin-inline:auto;\n}\n#mp-reviews-custom .mp-head{\n  text-align:center;\n  max-width:800px;\n  margin:0 auto 40px;\n}\n#mp-reviews-custom .mp-kicker{\n  font-size:12px;\n  letter-spacing:.13em;\n  text-transform:uppercase;\n  font-weight:800;\n  color:#683D0E;\n  margin-bottom:14px;\n}\n#mp-reviews-custom .mp-title{\n  margin:0;\n  font-size:32px;\n  line-height:1.18;\n  letter-spacing:.4px;\n  font-weight:800;\n  color:#121212;\n}\n#mp-reviews-custom .mp-carousel{\n  display:flex;\n  gap:22px;\n  overflow-x:auto;\n  scroll-snap-type:x mandatory;\n  scrollbar-width:none;\n  padding:8px 4px 22px;\n}\n#mp-reviews-custom .mp-carousel::-webkit-scrollbar{display:none}\n#mp-reviews-custom .mp-card{\n  flex:0 0 calc(33.333% - 15px);\n  min-width:330px;\n  scroll-snap-align:start;\n  background:#fff;\n  border:1px solid #eae5dc;\n  border-radius:14px;\n  padding:26px;\n}\n#mp-reviews-custom .mp-card-top{\n  display:flex;\n  align-items:center;\n  justify-content:space-between;\n  gap:14px;\n  margin-bottom:20px;\n}\n#mp-reviews-custom .mp-stars{\n  color:#ffb000;\n  letter-spacing:2px;\n  font-size:19px;\n}\n#mp-reviews-custom .mp-verified{\n  color:rgba(0,0,0,.62);\n  font-size:12px;\n  font-weight:700;\n}\n#mp-reviews-custom .mp-card h3{\n  margin:0 0 14px;\n  font-size:18px;\n  font-weight:700;\n  letter-spacing:.2px;\n  line-height:1.4;\n  color:#121212;\n}\n#mp-reviews-custom .mp-card p{\n  margin:0 0 14px;\n  color:rgba(0,0,0,.62);\n  line-height:1.65;\n  font-size:15px;\n}\n#mp-reviews-custom .mp-result{\n  margin:18px 0 22px;\n  padding:14px 16px;\n  border-radius:10px;\n  background:#f4ece0;\n  color:#4e2e0a;\n  font-weight:700;\n  font-size:15px;\n}\n#mp-reviews-custom .mp-person{\n  display:flex;\n  align-items:center;\n  gap:12px;\n}\n#mp-reviews-custom .mp-avatar{\n  width:42px;\n  height:42px;\n  border-radius:50%;\n  display:grid;\n  place-items:center;\n  background:#efe7d9;\n  font-weight:900;\n  color:#121212;\n}\n#mp-reviews-custom .mp-person strong{display:block;color:#121212}\n#mp-reviews-custom .mp-person span{font-size:13px;color:rgba(0,0,0,.62)}\n#mp-reviews-custom .mp-controls{\n  display:flex;\n  justify-content:center;\n  gap:12px;\n  margin-top:16px;\n}\n#mp-reviews-custom .mp-arrow{\n  width:46px;\n  height:46px;\n  border-radius:999px;\n  border:1px solid #121212;\n  background:#fff;\n  color:#121212;\n  font-size:24px;\n  cursor:pointer;\n  transition:.2s ease;\n}\n#mp-reviews-custom .mp-arrow:hover{\n  background:#121212;\n  color:#fff;\n}\n#mp-reviews-custom .mp-dots{\n  display:flex;\n  gap:8px;\n  align-items:center;\n  justify-content:center;\n  margin-top:16px;\n}\n#mp-reviews-custom .mp-dot{\n  width:8px;\n  height:8px;\n  border-radius:50%;\n  background:#ddd5c8;\n  border:0;\n  padding:0;\n  cursor:pointer;\n}\n#mp-reviews-custom .mp-dot.active{background:#683D0E}\n@media(max-width:700px){\n  #mp-reviews-custom{padding:15px 0}\n  #mp-reviews-custom .mp-head{margin-bottom:22px}\n  #mp-reviews-custom .mp-card-top{margin-bottom:11px}\n  #mp-reviews-custom .mp-card{\n    min-width:86%;\n    flex-basis:86%;\n  }\n  #mp-reviews-custom .mp-title{font-size:26px}\n}\n</style>\n\n<section id=\"mp-reviews-custom\">\n  <div class=\"mp-container\">\n    <div class=\"mp-head\">\n      <div class=\"mp-kicker\">Kundenrezensionen &middot; 4,7 von 5 Sternen</div>\n      <h2 class=\"mp-title\">Zum Verwechseln &auml;hnlich? Das sagen unsere Kunden.</h2>\n    </div>\n\n    <div class=\"mp-carousel\" data-mp-carousel>\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Riecht super frisch und kommt Aventus ziemlich nah.&ldquo;</h3>\n        <p>Wusste erst nicht genau, was mich erwartet, aber der Duft hat mich echt positiv &uuml;berrascht. H&auml;lt ordentlich und der Preis ist einfach deutlich besser.</p>\n        <p class=\"mp-result\">Nah am Original. Deutlich besserer Preis.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">MT</div>\n          <div>\n            <strong>Michael T.</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Ich hab vorher nie einen Duft-Dupe gefunden, der wirklich authentisch riecht.&ldquo;</h3>\n        <p>Das war meine erste Bestellung hier und ich bin echt begeistert. Ich kauf mein Parf&uuml;m ab jetzt nirgendwo anders mehr.</p>\n        <p class=\"mp-result\">Authentisch im Duft. Konstant gleich gut.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">SM</div>\n          <div>\n            <strong>Sebastian M&uuml;ller</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Die D&uuml;fte sind wirklich nah an den Originalen.&ldquo;</h3>\n        <p>Alle drei D&uuml;fte, die ich bestellt habe, riechen echt richtig gut und halten auch lange.</p>\n        <p class=\"mp-result\">Drei D&uuml;fte. Alle nah am Original.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">CP</div>\n          <div>\n            <strong>Clara P.</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Einer der besten D&uuml;fte, die ich seit Jahren gerochen habe.&ldquo;</h3>\n        <p>Die Noten sind einfach brutal gut. Der bleibt definitiv dauerhaft in meiner Sammlung.</p>\n        <p class=\"mp-result\">Bleibt dauerhaft in der Sammlung.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">EW</div>\n          <div>\n            <strong>Emilia Wagner</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Genau so einen Duft hab ich gesucht.&ldquo;</h3>\n        <p>Ich hab ewig nach D&uuml;ften gesucht, die hochwertig riechen und auch lange halten.</p>\n        <p class=\"mp-result\">Hochwertig im Duft. Lange Haltbarkeit.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">DR</div>\n          <div>\n            <strong>Daniel Roth</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Einer meiner absoluten Lieblingsd&uuml;fte.&ldquo;</h3>\n        <p>War super schnell da und riecht einfach richtig gut.</p>\n        <p class=\"mp-result\">Schnell geliefert. Richtig guter Duft.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">JH</div>\n          <div>\n            <strong>Jonas Hartmann</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n\n      <article class=\"mp-card\">\n        <div class=\"mp-card-top\">\n          <div class=\"mp-stars\" aria-label=\"5 von 5 Sternen\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n          <div class=\"mp-verified\">&#9679; Verifizierter K&auml;ufer</div>\n        </div>\n        <h3>&bdquo;Wow, einfach unglaublich gut.&ldquo;</h3>\n        <p>Am Anfang war ich etwas besorgt, weil sich die Lieferung verz&ouml;gert hat. Aber als das Parf&uuml;m angekommen ist und sich der Duft erst mal gesetzt hat: wow.</p>\n        <p class=\"mp-result\">Das Warten wert.</p>\n        <div class=\"mp-person\">\n          <div class=\"mp-avatar\">LM</div>\n          <div>\n            <strong>Lionel M.</strong>\n            <span>Verifizierter K&auml;ufer</span>\n          </div>\n        </div>\n      </article>\n    </div>\n\n    <div class=\"mp-controls\">\n      <button class=\"mp-arrow\" data-mp-prev aria-label=\"Vorherige Rezension\">&#8249;</button>\n      <button class=\"mp-arrow\" data-mp-next aria-label=\"N&auml;chste Rezension\">&#8250;</button>\n    </div>\n    <div class=\"mp-dots\" data-mp-dots></div>\n  </div>\n</section>\n\n<script>\n(function(){\n  var root = document.getElementById('mp-reviews-custom');\n  if (!root) return;\n  var carousel = root.querySelector('[data-mp-carousel]');\n  var dotsWrap = root.querySelector('[data-mp-dots]');\n  var cards = Array.prototype.slice.call(carousel.children);\n  if (!cards.length) return;\n\n  dotsWrap.innerHTML = '';\n  cards.forEach(function(_, i){\n    var dot = document.createElement('button');\n    dot.className = 'mp-dot' + (i === 0 ? ' active' : '');\n    dot.setAttribute('aria-label', 'Rezension ' + (i + 1));\n    dot.addEventListener('click', function(){\n      carousel.scrollTo({left: cards[i].offsetLeft - carousel.offsetLeft, behavior: 'smooth'});\n    });\n    dotsWrap.appendChild(dot);\n  });\n  var dots = Array.prototype.slice.call(dotsWrap.children);\n\n  function step(){ return cards[0].getBoundingClientRect().width + 22; }\n  root.querySelector('[data-mp-prev]').addEventListener('click', function(){\n    carousel.scrollBy({left: -step(), behavior: 'smooth'});\n  });\n  root.querySelector('[data-mp-next]').addEventListener('click', function(){\n    carousel.scrollBy({left: step(), behavior: 'smooth'});\n  });\n  carousel.addEventListener('scroll', function(){\n    var index = Math.round(carousel.scrollLeft / step());\n    dots.forEach(function(d, i){\n      d.classList.toggle('active', i === Math.min(index, dots.length - 1));\n    });\n  });\n})();\n</script>",
